<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="next_cloud_list">
            <field name="name">next_cloud list</field>
            <field name="model">nextcloud.host</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="server" />
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="next_cloud_form">
            <field name="name">next_cloud form</field>
            <field name="model">nextcloud.host</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="server" />
                            <field name="dav_path" />
                            <field name="user" />
                            <field name="password" password="True" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="next_cloud_action_window">
            <field name="name">Next Cloud Server</field>
            <field name="res_model">nextcloud.host</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>