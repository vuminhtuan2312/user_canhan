<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="ftp_host_list">
            <field name="name">ftp_host list</field>
            <field name="model">ftp.host</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="server" />
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="ftp_host_form">
            <field name="name">ftp_host form</field>
            <field name="model">ftp.host</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="server" />
                            <field name="port" />
                            <field name="user" />
                            <field name="password" password="True" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="ftp_host_action_window">
            <field name="name">FTP Server</field>
            <field name="res_model">ftp.host</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>