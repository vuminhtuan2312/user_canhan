<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_bizfly_table" model="ir.actions.act_window">
        <field name="name">Bảng Bizfly</field>
        <field name="res_model">bizfly.table.map</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_bizfly_table_tree" model="ir.ui.view">
        <field name="name">bizfly.table.map.tree</field>
        <field name="model">bizfly.table.map</field>
        <field name="arch" type="xml">
            <list>
                <field name="table_code"/>
                <field name="mapping_by"/>
                <field name="model_id"/>
            </list>
        </field>
    </record>
    <record id="view_bizfly_table_form" model="ir.ui.view">
        <field name="name">bizfly.table.map.form</field>
        <field name="model">bizfly.table.map</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_update_table"
                            string="Cập nhật lại bảng"
                            type="object"
                            class="oe_highlight"
                            />
                    <button name="action_check_mapping_key"
                            string="Kiểm tra tham số"
                            type="object"
                            class="oe_highlight"
                            />
                </header>
                <sheet>
                    <!-- HEADER -->
                    <group>
                        <group>
                            <field name="table_code" required="1"/>
                            <field name="mapping_by" widget="many2many_tags"/>
                            <field name="model_id"/>
                        </group>
                    </group>
                    <notebook>
                        <!-- TAB THỜI GIAN -->
                        <page string="Thời gian">
                            <group>
                                <field name="updated_at" readonly="1"/>
                            </group>
                        </page>
                        <page string="Giá trị tham số điền vào bảng">
                            <field name="table_param_ids">
                                <list delete="true" create="false">
                                    <field name="is_selection_field"/>
                                    <field name="name" readonly="1"/>
                                    <field name="type" readonly="1"/>
                                    <field name="key" readonly="1"/>
                                    <field name="mapping_key"/>
                                    <field name="accept_null" readonly="1"/>
                                    <field name="require" readonly="1"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name" readonly="1"/>
                                        <field name="type" readonly="1"/>
                                        <field name="key" readonly="1"/>
                                        <field name="mapping_key"/>
                                        <field name="accept_null" readonly="1"/>
                                        <field name="require" readonly="1"/>
                                        <field name="is_selection_field"/>
                                    </group>
                                    <notebook>
                                        <page string="Lựa chọn giá trị">
                                            <field name="param_mapping_line_ids">
                                                <list editable="bottom" delete="true" create="false">
                                                    <field name="key" readonly="1"/>
                                                    <field name="value" readonly="1"/>
                                                    <field name="mapping_value"/>
                                                </list>
                                            </field>
                                        </page>
                                    </notebook>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
