<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_zalo_template" model="ir.actions.act_window">
        <field name="name">Zalo Templates</field>
        <field name="res_model">zalo.template</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_zalo_template_tree" model="ir.ui.view">
        <field name="name">zalo.tree</field>
        <field name="model">zalo.template</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_get_templates"
                    type="object"
                    string="Lấy danh sách template"
                    class="btn-primary"
                    display="always"
                    />
                    <button name="action_create_template_wizard"
                    type="object"
                    string="Tạo mới template"
                    class="btn-primary"
                    display="always"
                    />
                </header>

                <field name="template_name"/>
                <field name="template_id"/>
                <field name="default_template"/>
                <field name="created_at"/>
            </list>
        </field>
    </record>
    <record id="view_zalo_message_template_form" model="ir.ui.view">
        <field name="name">zalo.template.form</field>
        <field name="model">zalo.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="update_template"
                            string="Cập nhật lại template"
                            type="object"
                            class="oe_highlight"
                            />
                    <button name="action_check_mapping_key"
                            string="Kiểm tra tham số"
                            type="object"
                            class="oe_highlight"
                            />
                </header>
                <sheet>
                    <!-- HEADER -->
                    <group>
                        <group>
                            <field name="template_id" readonly="1"/>
                            <field name="template_name"/>
                            <field name="type"/>
                            <field name="template_status"/>
                        </group>
                        <group>
                            <field name="template_quality"/>
                            <field name="template_tag"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- TAB THÔNG TIN CHUNG -->
                        <page string="Thông tin chung">
                            <group>
                                <group>
                                    <field name="timeout"/>
                                    <field name="preview_url"/>
                                </group>
                                <group>
                                    <field name="is_journey"/>
                                    <field name="token_type"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB GIÁ & HẠN MỨC -->
                        <page string="Giá và Hạn mức">
                            <group>
                                <group>
                                    <field name="price"/>
                                    <field name="price_exceeded"/>
                                    <field name="retail_price"/>
                                </group>
                                <group>
                                    <field name="apply_template_quota"/>
                                    <field name="template_daily_quota"/>
                                    <field name="template_remaining_quota"/>
                                </group>
                            </group>
                        </page>
                        <!-- TAB THỜI GIAN -->
                        <page string="Thời gian">
                            <group>
                                <group>
                                    <field name="created_at" readonly="1"/>
                                </group>
                                <group>
                                    <field name="updated_at" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Giá trị tham số điền template">
                            <field name="template_param_ids">
                                <list editable="bottom" delete="false" create="false">
                                    <field name="name" readonly="1"/>
                                    <field name="type" readonly="1"/>
                                    <field name="mapping_key"/>
                                    <field name="accept_null" readonly="1"/>
                                    <field name="require" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
