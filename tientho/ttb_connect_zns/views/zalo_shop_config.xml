<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_zalo_shop_config_form" model="ir.ui.view">
        <field name="name">zalo.shop.config.form</field>
        <field name="model">zalo.shop.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_get_templates"
                            string="Get Templates"
                            type="object"
                            class="oe_highlight"
                            />
                    <button name="action_create_template_wizard"
                            string="Tạo Template Mới"
                            type="object"
                            class="oe_highlight"
                            />
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="access_token" password="True"/>
                        <field name="zalo_shop_id"/>
                        <field name="api_key"/>
                        <field name="oa_id"/>
                        <field name="active"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>
                    <notebook>
                        <page string="Update Webhook ZNS">
                            <group>
                                <field name="webhook_url"/>
                                <field name="oa_app_id"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                Sau khi cấu hình webhook, vui lòng bấm nút "Cập nhật Webhook" bên dưới để hệ thống gửi yêu cầu cập nhật webhook đến Zalo Shop.
                            </div>
                            <button name="action_update_webhook_url"
                                    string="Cập nhật Webhook"
                                    type="object"
                                    class="oe_highlight"
                                    />
                        </page>
                        <page string="Cấu hình Bizfly">
                            <group>
                                <field name="project_key_bizfly" widget="password" groups="base.group_system"/>
                                <field name="api_key_bizfly" groups="base.group_system"/>
                                <field name="api_secret_key_bizfly" groups="base.group_system"/>
                                <field name="api_embed_key_bizfly" groups="base.group_system"/>
                            </group>
                        </page>
                        <page string="Danh sách mã lỗi Zalo">
                            <group>
                                <field name="zns_api_code_error_ids">
                                    <list string="Mã lỗi Zalo API" readonly="1">
                                        <field name="code"/>
                                        <field name="message"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_zalo_shop_config_tree" model="ir.ui.view">
        <field name="name">zalo.shop.config.tree</field>
        <field name="model">zalo.shop.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="zalo_shop_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="action_zalo_shop_config" model="ir.actions.act_window">
        <field name="name">Zalo Shops</field>
        <field name="res_model">zalo.shop.config</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>
