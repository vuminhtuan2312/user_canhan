<odoo>
    <record id="view_webhook_response_tree" model="ir.ui.view">
        <field name="name">webhook.response.tree</field>
        <field name="model">webhook.response</field>
        <field name="arch" type="xml">
            <list string="Webhook Responses" create="false" delete="false">
                <field name="timestamp"/>
                <field name="event_name"/>
                <field name="app_id"/>
                <field name="oa_id"/>
                <field name="msg_id"/>
                <field name="tracking_id"/>
                <field name="sender_id"/>
                <field name="recipient_id"/>
                <field name="message_text"/>
            </list>
        </field>
    </record>

    <record id="view_webhook_response_form" model="ir.ui.view">
        <field name="name">webhook.response.form</field>
        <field name="model">webhook.response</field>
        <field name="arch" type="xml">
            <form string="Webhook Response" create="false" edit="false" delete="false">
                <sheet>

                    <group col="4">
                        <field name="name"/>
                        <field name="event_name"/>
                        <field name="timestamp"/>
                        <field name="app_id"/>
                        <field name="oa_id"/>
                        <field name="zns_send"/>
                    </group>

                    <group col="4">
                        <field name="msg_id"/>
                        <field name="tracking_id"/>
                        <field name="delivery_time"/>
                        <field name="submit_time"/>
                    </group>

                    <group col="4">
                        <field name="sender_id"/>
                        <field name="sender_admin_id"/>
                        <field name="recipient_id"/>
                        <field name="user_id_by_app"/>
                    </group>

                    <notebook>

                        <!-- Message -->
                        <page string="Nội dung">
                            <group>
                                <field name="message_text" widget="text"/>
                            </group>
                        </page>

                        <!-- Media -->
                        <page string="Media">
                            <group col="4">
                                <field name="image_url"/>
                                <field name="image_thumbnail"/>
                                <field name="sticker_id"/>
                                <field name="sticker_url"/>
                            </group>

                            <group col="4">
                                <field name="file_name"/>
                                <field name="file_type"/>
                                <field name="file_size"/>
                                <field name="file_url"/>
                                <field name="file_checksum"/>
                            </group>

                            <group col="4">
                                <field name="link_title"/>
                                <field name="link_description"/>
                                <field name="link_url"/>
                                <field name="link_thumbnail"/>
                            </group>
                        </page>

                        <!-- Button / Consent -->
                        <page string="Tương tác">
                            <group col="4">
                                <field name="button_type"/>
                                <field name="rate"/>
                                <field name="phone"/>
                                <field name="request_type"/>
                            </group>

                            <group col="4">
                                <field name="consent_create_time"/>
                                <field name="consent_expired_time"/>
                            </group>
                        </page>

                        <!-- Raw payload -->
                        <page string="Raw Payload">
                            <field name="raw_payload" widget="text"/>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_webhook_config" model="ir.actions.act_window">
        <field name="name">Webhooks</field>
        <field name="res_model">webhook.response</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
