<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_refuse_campaign_wizard_form" model="ir.ui.view">
        <field name="name">refuse.campaign.wizard.form</field>
        <field name="model">refuse.campaign.wizard</field>
        <field name="arch" type="xml">
            <form string="Từ chối chiến dịch">
                <group>
                    <field name="reason"/>
                </group>

                <footer>
                    <button name="action_confirm_refuse"
                            type="object"
                            string="Xác nhận từ chối"
                            class="btn-danger"/>

                    <button string="Hủy"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
