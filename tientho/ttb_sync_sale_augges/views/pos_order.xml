<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_pos_pos_form" model="ir.ui.view">
        <field name="name">pos.order.form</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='order_fields']" position="after">
                <group>
                    <field name="id_quay_augges" readonly="1"/>
                    <field name="sp_augges" readonly="1"/>
                    <field name="warehouse_id" invisible="1"/>
                    <field name="ttb_branch_id" readonly="1"/>
                    <field name="augges_no_tk" readonly="1"/>
                    <field name="keep_pos_discount"/>
                    <field name="ttb_einvoice_manual"/>
                    <field name="is_personalized_invoice"/>
                    <field name="partner_vat"  invisible="not is_personalized_invoice"/>
                    <field name="partner_name" invisible="not is_personalized_invoice" required="is_personalized_invoice"/>
                    <field name="partner_address" invisible="not is_personalized_invoice" required="is_personalized_invoice"/>
                    <field name="partner_email" invisible="not is_personalized_invoice"/>
                    <field name="partner_phone" invisible="not is_personalized_invoice"/>
                    <field name="code_qhns" invisible="not is_personalized_invoice"/>
                    <field name="is_invoice_origin" invisible="not is_personalized_invoice"/>
                    <field name="ttb_total_point_earn"/>
                    <field name="ttb_total_point_spent"/>
                </group>
            </xpath>

            <xpath expr="//field[@name='lines']//list//field[@name='tax_ids']" position="attributes">
                <attribute name="column_invisible">False</attribute>
                <attribute name="readonly">0</attribute>
            </xpath>

            <xpath expr="//field[@name='lines']//list//field[@name='tax_ids_after_fiscal_position']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            
            <xpath expr="//field[@name='lines']//form//field[@name='tax_ids']" position="attributes">
                <attribute name="invisible">0</attribute>
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='lines']//form//field[@name='tax_ids_after_fiscal_position']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

</odoo>
