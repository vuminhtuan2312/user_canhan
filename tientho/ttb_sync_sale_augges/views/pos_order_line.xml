<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_pos_order_line_invoice" model="ir.ui.view">
        <field name="name">pos.order.line.list</field>
        <field name="model">pos.order.line</field>
        <field name="mode">primary</field>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <list string="Chi tiết đơn POS xuất hóa đơn" create="0" delete="0" editable="bottom">
                <field name="ttb_branch_id" readonly="1"/>
                <field name="order_id" string="Mã đơn hàng" readonly="1"/>
                <field name="product_id" readonly="1"/>
                <field name="qty" readonly="1" sum="Total qty"/>
                <field name="purchase_invoiced_qty" readonly="1" sum="Total purchase_invoiced_qty"/>
                <field name="invoiced_done_qty" readonly="1" sum="Total invoiced_done_qty"/>
                <field name="price_unit" readonly="1" widget="monetary"/>
                <field name="invoice_date"/>
            </list>
        </field>
    </record>

    <record id="view_pos_order_line_invoice_search" model="ir.ui.view">
        <field name="name">pos.order.line.search</field>
        <field name="model">pos.order.line</field>
        <field name="mode">primary</field>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <search>
                <field name="order_id" string="Mã đơn hàng" readonly="1"/>
                <field name="ttb_branch_id" readonly="1"/>
                <field name="product_id" readonly="1"/>
                <group string="Group By">
                    <filter string="Mã đơn hàng" name="group_by_order_id" context="{'group_by': 'order_id'}"/>
                    <filter string="Cơ sở" name="group_by_ttb_branch_id" context="{'group_by': 'ttb_branch_id'}"/>
                    <filter string="Sản phẩm" name="group_by_product_id" context="{'group_by': 'product_id'}"/>
                    <filter string="Ngày xuất hóa đơn" name="group_by_invoice_date" context="{'group_by': 'invoice_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="pos_order_line_invoice_action" model="ir.actions.act_window">
        <field name="name">Đơn POS</field>
        <field name="res_model">pos.order.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_pos_order_line_invoice"/>
        <field name="search_view_id" ref="view_pos_order_line_invoice_search"/>
        <field name="domain">[('purchase_invoiced_qty', '>', 0)]</field>
    </record>

    <menuitem
        id="pos_order_line_invoice_menu"
        name="Đơn POS"
        parent="purchase.purchase_report_main"
        action="pos_order_line_invoice_action"
        sequence="195"
    />

</odoo>
