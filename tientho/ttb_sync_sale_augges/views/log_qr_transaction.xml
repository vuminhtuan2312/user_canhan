<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_qr_transaction" model="ir.ui.view">
        <field name="name">log.qr.transaction.list</field>
        <field name="model">log.qr.transaction</field>
        <field name="arch" type="xml">
            <list string="Chi tiết giao dịch QR" create="0" delete="0">
                <field name="id_transaction" optional="hide"/>
                <field name="id_hd" />
                <field name="ma_Hd" optional="hide"/>
                <field name="mid" optional="hide"/>
                <field name="tid" optional="hide"/>
                <field name="account_name" optional="hide"/>
                <field name="created_QR_on" optional="hide"/>
                <field name="amount"/>
                <field name="ma_kho"/>
                <field name="state" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_qr_transaction_search" model="ir.ui.view">
        <field name="name">log.qr.transaction.search</field>
        <field name="model">log.qr.transaction</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm giao dịch QR">
                <field name="id_hd"/>
                <field name="created_QR_on" filter_domain="[('created_on','=',self)]"/>
                <filter name="state" string="Thành công" domain="[('state','=','success')]" />
            </search>
        </field>
    </record>

    <record id="qr_transaction_action" model="ir.actions.act_window">
        <field name="name">Giao dịch QR</field>
        <field name="res_model">log.qr.transaction</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_qr_transaction"/>
        <field name="context">{'search_default_state': 1}</field>
    </record>

    <menuitem
        id="qr_transaction_menu"
        name="Giao dịch QR"
        parent="ttb_purchase.purchase_order_accounting_root_menu"
        action="qr_transaction_action"
        sequence="196"
    />
</odoo>
