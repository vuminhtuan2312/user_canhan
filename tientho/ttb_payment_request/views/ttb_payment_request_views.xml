<odoo>
    <!-- Khai báo Hành động In (Report Action) -->
    <record id="action_report_payment_request" model="ir.actions.report">
        <field name="name">Phiếu Đề Nghị Thanh Toán</field>
        <field name="model">ttb.payment.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ttb_payment_request.report_payment_request_template</field>
        <field name="report_file">ttb_payment_request.report_payment_request_template</field>
        <field name="print_report_name">(object.name or 'DNTT').replace('/', '_')</field>
        <field name="binding_model_id" ref="model_ttb_payment_request"/>
        <field name="binding_type">report</field>
    </record>
    <!-- Form View -->
    <record id="view_payment_request_form" model="ir.ui.view">
        <field name="name">ttb.payment.request.form</field>
        <field name="model">ttb.payment.request</field>
        <field name="arch" type="xml">
            <form string="Đề xuất thanh toán">
                <header>
                    <!-- Quy trình phê duyệt -->
                    <field name="sent_ok" invisible="1"/>
                    <field name="approve_ok" invisible="1"/>
                    <!-- <field name="locker_ok" invisible="1"/> -->
                    <button name="action_sent" string="Gửi duyệt" invisible="not sent_ok or state != 'draft'" type="object" class="btn-primary"/>
                    <button name="action_approve" string="Duyệt" invisible="not approve_ok or state != 'sent'" type="object" class="btn-primary"/>
                    <button name="action_reject" string="Từ chối" invisible="not approve_ok or state != 'sent'" type="object"/>
                    <button name="action_cancel" string="Hủy" invisible="state != 'draft'" type="object"/>
                    <button name="action_reset_to_draft" string="Về mới" type="object"
                        invisible="state != 'cancelled'"/>
                    <!-- <button name="%(ttb_payment_request.action_report_payment_request)d"  -->
                    <button name="action_print_and_mark_as_printed" 
                        type="object" 
                        string="In Phiếu" 
                        class="btn-secondary"
                        invisible="state != 'approved'"/>
                    <!-- end quy trình phê duyệt -->
                    <!-- <field name="state" widget="statusbar" statusbar_visible="draft,to_approve,approved,rejected,cancelled"/> -->
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_purchase_order" class="oe_stat_button" icon="fa-pencil-square-o" invisible="not purchase_order_id">
                            <span>Đơn mua hàng</span>
                        </button>
                    </div>
                    <!-- <field name="is_printed" invisible="1"/> -->
                    <widget name="web_ribbon" title="Đã in phiếu" bg_color="text-bg-success" invisible="not is_printed"/>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <group string="Thông tin đơn hàng">
                            <field name="purchase_order_id"/>
                            <field name="amount_total_purchase"/>
                            <field name="amount_paid"/>
                            <field name="amount_remain"/>
                        </group>
                        <group string="Thông tin đề xuất">
                            <field name="user_id" readonly="1"/>
                            <field name="payment_type"/>
                            <field name="amount_total"/>
                            <field name="percent_total" invisible="payment_type == 'request'" widget="percentage"/>
                            <!-- <field name="percent_total" invisible="payment_type == 'request'"/> -->
                            <field name="note"/>
                        </group>
                        <group string="Chứng từ">
                            <field name="ttb_type" invisible="1"/>
                            
                            <field name="file_invoice" widget="pdf_viewer"/>

                            <!-- Hàng kinh doanh -->
                            <!-- self.ttb_receipt_doc = self.purchase_order_id.ttb_receipt_doc -->
                            <!-- self.ttb_vendor_doc = self.purchase_order_id.ttb_vendor_doc -->
                            <field name="ttb_receipt_doc" widget="pdf_viewer" invisible="ttb_type != 'sale' or payment_type == 'advance'"/>
                            <field name="ttb_vendor_doc" widget="pdf_viewer" invisible="ttb_type != 'sale' or payment_type == 'advance'"/>

                            <!-- Đơn mua hàng Không kinh doanh -->
                            <!-- self.ttb_vendor_delivery = self.purchase_order_id.ttb_vendor_delivery -->
                            <!-- self.ttb_acceptance_report = self.purchase_order_id.ttb_acceptance_report -->
                            <field name="file_contract" widget="pdf_viewer"/>                            
                            <field name="ttb_vendor_delivery" widget="pdf_viewer" invisible="ttb_type == 'sale' or payment_type == 'advance'"/>
                            <field name="ttb_acceptance_report" widget="pdf_viewer" invisible="ttb_type == 'sale' or payment_type == 'advance'"/>
                            <field name="file_others" widget="many2many_binary" invisible="ttb_type == 'sale' or payment_type == 'advance'"/>
                        </group>
                        <group string="Thông tin thanh toán">
                            <!-- <field name="account_type_from"/> -->
                            <field name="due_date" required="1"/>
                            <field name="payment_method" required="1"/>
                            <field name="partner_id" domain="[('user_ids','!=',[])]" invisible="payment_type != 'advance'" required="1"/>
                            <field name="partner_id" invisible="payment_type == 'advance'" required="1"/>
                            <field name="bank_account_name" required="1"/>
                            <field name="bank_account_number" required="1"/>
                            <field name="bank_id" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thông tin phê duyệt" name="approval_info">
                            <group>
                                <group>
                                    <field name="current_approve_user_ids" readonly="1" widget="many2many_tags"/>
                                    <field name="next_approve_user_ids" readonly="1" widget="many2many_tags"/>
                                    <field name="notif_user_ids" readonly="1" widget="many2many_tags"/>
                                </group>
                                <group groups="base.group_no_one">
                                    <!-- <field name="process_id" readonly="1" groups="base.group_no_one"/> -->
                                    <!-- <field name="date_sent" readonly="1" groups="base.group_no_one"/> -->
                                    <field name="date_approved" readonly="1" groups="base.group_no_one"/>
                                </group>
                            </group>
                            <field name="rule_line_ids"/>
                        </page>
                    </notebook>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_payment_request_tree" model="ir.ui.view">
        <field name="name">ttb.payment.request.tree</field>
        <field name="model">ttb.payment.request</field>
        <field name="arch" type="xml">
            <list string="Đề xuất thanh toán">
                <field name="name"/>
                <field name="purchase_order_id"/>
                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="state"/>
            </list>
        </field>
    </record>
</odoo>