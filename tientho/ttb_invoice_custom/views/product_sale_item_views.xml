<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_sale_item_form" model="ir.ui.view">
        <field name="name">product.sale.item.form</field>
        <field name="model">product.sale.item</field>
        <field name="inherit_id" ref="ttb_product.view_product_sale_item_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='batch_name']" position="after">
                <field name="misa_product_id"/>
                <field name="count_out_product"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="match_out_product" string="Sản phẩm bán ra đã ghép">
                    <field name="out_product_ids">
                        <list>
                            <field name="out_product_id"/>
                            <field name="quantity" sum="Total"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
