<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="wizard_login_as_form" model="ir.ui.view">
            <field name="name">Chọn User</field>
            <field name="model">wizard.login_as</field>
            <field name="arch" type="xml">
                <form string="Chọn User">
                    <group>
                        <field name="user_id"/>
                    </group>
                    <footer>
                        <button name="action_login_as" string="Login" type="object" class="btn-primary"/>
                        <button string="Hủy bỏ" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="wizard_login_as_action" model="ir.actions.act_window">
            <field name="name">Chọn User</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">wizard.login_as</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
