<odoo>
  <record id="view_budget_adjustment_form" model="ir.ui.view">
  <field name="name">fsapp.budget.adjustment.form</field>
  <field name="model">fsapp.budget.adjustment</field>
  <field name="arch" type="xml">
    <form string="Điều chỉnh ngân sách">
      <header>
        <field name="state" widget="statusbar" statusbar_visible="draft,waiting,approved,rejected,cancelled"/>
        <field name="can_submit" invisible="1"/>
        <field name="can_cancel" invisible="1"/>
        <field name="can_approve" invisible="1"/>
        <field name="can_reset" invisible="1"/>

        <button name="action_submit" type="object" string="Gửi duyệt" class="btn-primary"
                invisible="not can_submit"/>
        <button name="action_cancel" type="object" string="Hủy"
                invisible="not can_cancel"/>
        <button name="action_approve" type="object" string="Duyệt" class="btn-primary"
                invisible="not can_approve"/>
        <button name="action_reject" type="object" string="Không duyệt"
                invisible="not can_approve"/>
        <button name="action_reset_to_draft" type="object" string="Về mới"
                invisible="not can_reset"/>
      </header>

      <sheet>
        <h1>
          <field name="name" readonly="state in ['waiting', 'approved']"/>
        </h1>

        <group>
          <group>
            <field name="proposer_id" readonly="state in ['waiting', 'approved']"/>
            <field name="budget_id" readonly="state in ['waiting', 'approved']"/>
          </group>
          <group>
            <field name="project_budget_id"/>
            <field name="date_from"/>
            <field name="date_to"/>
            <field name="approve_user_id"/>
            <field name="total_adjustment" widget="monetary"/>
          </group>
        </group>

        
            <field name="adjustment_line_ids" readonly="state in ['waiting', 'approved']">
              <list editable="bottom">
                <field name="cost_group"/>
                <field name="analytic_account_id"/>
                <field name="planned_cost"/>
                <field name="description"/>
              </list>
            </field>
          
          <div class="oe_chatter">
          <field name="message_follower_ids" widget="mail_followers"/>
          <field name="message_ids" widget="mail_thread"/>
        </div>
      </sheet>
    </form>
  </field>
</record>

  <!-- View list -->
  <record id="view_budget_adjustment_tree" model="ir.ui.view">
    <field name="name">fsapp.budget.adjustment.tree</field>
    <field name="model">fsapp.budget.adjustment</field>
    <field name="arch" type="xml">
      <list string="Điều chỉnh ngân sách">
        <field name="name"/>
        <field name="budget_id"/>
        <field name="proposer_id"/>
      </list>
    </field>
  </record>

  <!-- Action -->
  <record id="action_budget_adjustment" model="ir.actions.act_window">
    <field name="name">Điều chỉnh ngân sách</field>
    <field name="res_model">fsapp.budget.adjustment</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- Menu -->
  <menuitem id="menu_budget_adjustment"
            name="Điều chỉnh ngân sách"
            parent="menu_fsapp_budget_root"
            action="action_budget_adjustment"
            sequence="20"/>
</odoo>