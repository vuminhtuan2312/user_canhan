<odoo>
<!-- Smart Button: Phiếu chi -->
<record id="view_payment_request_form" model="ir.ui.view">
  <field name="name">fsapp.payment.request.form</field>
  <field name="model">fsapp.payment.request</field>
  <field name="inherit_id" ref="your_module.view_payment_request_form"/> <!-- Thay 'your_module' nếu cần -->
  <field name="arch" type="xml">
    <xpath expr="//form/sheet" position="before">
      <div class="oe_button_box" name="button_box">
        <button name="%(account.action_account_payments)d"
                type="action"
                class="oe_stat_button"
                icon="fa-money"
                invisible="not payment_id"/>
          <field name="payment_id" invisible="1"/>
          <div class="o_stat_info">
            <span class="o_stat_text">Phiếu chi</span>
          </div>
        </button>
      </div>
    </xpath>
  </field>
</record>
</odoo>