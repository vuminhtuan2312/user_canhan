<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_applicant_refuse_reason_form" model="ir.ui.view">
        <field name="name">applicant.get.refuse.reason.form</field>
        <field name="model">applicant.get.refuse.reason</field>
        <field name="inherit_id" ref="hr_recruitment.applicant_get_refuse_reason_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='template_id']" position="after">
                <field name="send_date" invisible="not send_mail" required="send_mail"/>
            </xpath>
        </field>
    </record>
</odoo>