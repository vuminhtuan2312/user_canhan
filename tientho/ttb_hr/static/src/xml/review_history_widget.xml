<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ttb_hr.ReviewInfoWidget" owl="1">
        <style>
            .o_review_info_widget .timeline {
                position: relative;
                padding-left: 40px;
                list-style: none;
            }
            .o_review_info_widget .timeline::before {
                content: '';
                position: absolute;
                top: 15px;
                bottom: 15px;
                left: 15px;
                width: 3px;
                background-color: #0d6efd;
                border-radius: 2px;
            }
            .o_review_info_widget .timeline-item {
                position: relative;
            }
            .o_review_info_widget .timeline-item:not(:last-child) {
                 margin-bottom: 1.5rem;
            }
            .o_review_info_widget .timeline-item::before {
                content: '';
                position: absolute;
                top: 12px;
                left: -34px;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background-color: #0d6efd;
                border: 4px solid #ffffff;
                z-index: 1;
            }
            .o_review_info_widget .stage-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 0.5rem;
            }
            .o_review_info_widget .stage-info {
                display: flex;
                align-items: center;
                gap: 1rem;
                flex-wrap: wrap;
            }
            .o_review_info_widget .reviewer-info {
                font-size: 0.875rem;
                color: #6c757d;
                display: flex;
                align-items: center;
                gap: 0.25rem;
            }
            .o_review_info_widget .stage-result-badge {
                flex-shrink: 0;
            }
        </style>
        <div class="o_review_info_widget">
            <t t-if="groupedReviews.length > 0">
                <div class="timeline">
                    <t t-foreach="groupedReviews" t-as="group" t-key="group.stageId">
                        <div class="timeline-item">
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <div class="stage-header">
                                        <strong><t t-esc="group.stageName"/></strong>
                                        <t t-if="group.stageResult">
                                            <div class="stage-info">
                                                <div class="reviewer-info">
                                                    <i class="fa fa-user"></i>
                                                    <span><t t-esc="group.stageResult.reviewer"/></span>
                                                </div>
                                                <div class="stage-result-badge">
                                                    <t t-if="group.stageResult.result === 'yes'">
                                                        <span class="badge bg-success">Đạt</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge bg-danger">Không đạt</span>
                                                    </t>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <ul class="list-group list-group-flush">
                                    <t t-foreach="group.reviews" t-as="review" t-key="review.id">
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-bold"><t t-esc="review.name"/></div>
                                                <small class="text-muted"><t t-esc="review.content"/></small>
                                            </div>
                                            <t t-if="review.is_pass === 'yes'">
                                                <span class="badge bg-success rounded-pill">Đạt</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge bg-danger rounded-pill">Không Đạt</span>
                                            </t>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
            <t t-else="">
                <div class="alert alert-info" role="alert">
                    Chưa có thông tin đánh giá nào.
                </div>
            </t>
        </div>
    </t>
</templates>