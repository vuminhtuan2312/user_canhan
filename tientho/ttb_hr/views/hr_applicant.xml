<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hr_applicant_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.applicant.view.form</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='job_id']" position="before">
                <field name="cv_pdf_file"
                       string="Upload CV PDF"
                       invisible="cv_pdf_file != False"
                       help="Upload file PDF CV để tự động trích xuất thông tin"/>
                <field name="temp_partner_phone" invisible="1"/>
                <field name="temp_email_from" invisible="1"/>
            </xpath>
            <xpath expr="//page[@name='application_note']" position="after">
                <page string="Thông tin xét tuyển">
                    <group string="Kết quả vòng">
                        <field nolabel="1" name="test_result_ids" invisible="1">
                            <list>
                                <field name="stage_id"/>
                                <field name="result"/>
                                <field name="reviewer_id"/>
                            </list>
                        </field>
                        <field nolabel="1" name="test_result_display_ids" widget="one2many_result_check">
                            <list editable="bottom" create="0" delete="0">
                                <field name="can_check" invisible="1"/>
                                <field name="stage_id" readonly="1"/>
                                <field name="result" readonly="1"/>
                                <field name="reviewer_id"/>
                                <button name="button_pass_stage" type="object" string="Đạt"
                                        class="btn btn-success btn-sm" invisible="not can_check"/>
                                <button name="button_reject_stage" type="object" string="Không đạt"
                                        class="btn btn-danger btn-sm" invisible="not can_check"/>
                            </list>
                        </field>
                    </group>
                    <group string="Tiêu chí đánh giá">
                        <field nolabel="1" name="review_infor_display_ids">
                            <list editable="bottom" create="0" default_order="sequence asc">
                                <field name="can_check" invisible="1"/>
                                <field name="sequence" optional="hide"/>
                                <field name="stage_name" optional="hide"/>
                                <field name="name"/>
                                <field name="content"/>
                                <field name="is_pass" readonly="1"/>
                                <field name="reviewer_id"/>
                                <button name="button_pass_job" type="object" string="Đạt"
                                        class="btn btn-success btn-sm" invisible="not can_check"/>
                                <button name="button_reject_job" type="object" string="Không đạt"
                                        class="btn btn-danger btn-sm" invisible="not can_check"/>
                            </list>
                        </field>
                        <field nolabel="1" name="review_infor_ids" invisible="1">
                            <list editable="bottom" create="0" default_order="sequence asc">
                                <field name="sequence" optional="hide"/>
                                <field name="stage_name" optional="hide"/>
                                <field name="name"/>
                                <field name="content"/>
                                <field name="is_pass" readonly="1"/>
                            </list>
                        </field>
                    </group>
                </page>
                <page string="Lịch sử đánh giá">
                    <group>
                        <group>
                            <field name="review_infor_ids" widget="review_info_widget" readonly="1"/>
                        </group>
                        <group>
                            <field name="applicant_notes" type="html" string="Ghi chú"
                                   options="{'collaborative': true, 'resizable': false}"
                                   placeholder="Internal notes..."/>
                        </group>
                    </group>
                </page>
                <page string="CV ứng viên" invisible="cv_pdf_file == False">
                    <group>
                        <field name="cv_pdf_file"
                               string="Upload CV PDF"
                               widget="pdf_viewer"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//page[@name='application_note']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='application_details']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='stage_id']" position="attributes">
                <attribute name="widget">statusbar_duration_show_pop_up</attribute>
            </xpath>
            <xpath expr="//field[@name='email_from']" position="before">
                <field name="recruitment_requirements_id"/>
            </xpath>
            <xpath expr="//field[@name='linkedin_profile']" position="after">
                <field name="platform_ids" invisible="1"/>
                <field name="platform" domain="[('id', 'in', platform_ids)]"/>
            </xpath>
        </field>
    </record>

    <record id="hr_kanban_view_applicant_inherit_schedule" model="ir.ui.view">
        <field name="name">hr.applicant.kanban.inherit.schedule</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_kanban_view_applicant"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="js_class">hr_applicant_kanban_with_wizard</attribute>
            </xpath>
        </field>
    </record>

</odoo>