<odoo>
    <record id="view_update_product_attribute_value_wizard" model="ir.ui.view">
        <field name="name">update.product.attribute.value.wizard.form</field>
        <field name="model">update.product.attribute.value.wizard</field>
        <field name="arch" type="xml">
            <form string="Cập nhật thuộc tính">
                <field name="attribute_line_ids" widget="one2many" context="{'show_attribute': False}">
                    <list editable="top" delete="false" create="false">
                        <field name="sequence" widget="handle"/>
                        <field name="attribute_id" readonly="1" force_save="1"/>
                        <field name="value_ids" widget="many2many_tags"/>
                        <field name="mch5_value_ids" widget="many2many_tags" readonly="1" force_save="1"/>
                    </list>
                </field>
                <footer>
                    <button name="action_confirm" type="object" class="btn-primary" string="Xác nhận"/>
                    <button special="cancel" string="Hủy"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>