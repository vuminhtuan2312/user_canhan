<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_product_nibot_view_list" model="ir.ui.view">
        <field name="name">ttb.product.nibot.list</field>
        <field name="model">ttb.product.nibot</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="name_origin" optional="hide"/>
                <field name="price"/>
                <field name="product_id"/>
                <field name="price_odoo"/>
                <field name="diff_name"/>
                <!-- <field name="processed"/> -->
            </list>
        </field>
    </record>

    <record id="ttb_product_nibot_view_form" model="ir.ui.view">
        <field name="name">ttb.product.nibot.list</field>
        <field name="model">ttb.product.nibot</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="diff_name"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="price_odoo"/>
                            <field name="name_origin"/>
                            <field name="note" />
                            <!-- <field name="processed"/> -->
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ttb_product_nibot_action" model="ir.actions.act_window">
        <field name="name">Sản phẩm nibot</field>
        <field name="res_model">ttb.product.nibot</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="ttb_product_nibot_menu"
        name="Sản phẩm Nibot"
        parent="ttb_purchase.purchase_order_accounting_root_menu"
        action="ttb_product_nibot_action"
        sequence="10"
    />
</odoo>