<odoo>
    <record id="ttb_substitude_product_view_list" model="ir.ui.view">
        <field name="name">ttb.substitute.product.list</field>
        <field name="model">ttb.substitute.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="priority"/>
                <field name="product_template_id"/>
                <field name="product_id"/>
                <field name="different_price"/>
                <field name="different"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>
</odoo>
