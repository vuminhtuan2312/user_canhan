        <field name="domain">[("branch_id", "=", 15)]</field>
        <field name="context">{"default_branch_id": 15}</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_mch_setter_branch_15" name="Nguyễn Trãi"
