<odoo>
    <record id="product_mch_setter_list" model="ir.ui.view">
        <field name="name">product.mch.setter.list</field>
        <field name="model">product.mch.setter</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_id"/>
                <field name="default_code"/>
                <field name="list_price" optional="show"/>
                <field name="branch_id" optional="show"/>
                <field name="categ_id_level_1"/>
                <field name="categ_id_level_2"/>
                <field name="categ_id_level_3"/>
                <field name="categ_id_level_4"/>
                <field name="categ_id_level_5"/>
                <field name="user_id"/>
                <field name="processed"/>
                <field name="menu_type" optional="show"/>
            </list>
        </field>
    </record>

    <record id="product_mch_setter_form" model="ir.ui.view">
        <field name="name">product.mch.setter.list</field>
        <field name="model">product.mch.setter</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_processed_and_next" type="object" string="Xác nhận" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="default_code" readonly="1"/>
                        <field name="list_price" optional="show" readonly="1"/>
                        <field name="branch_id" optional="show"/>
                        <field name="categ_id_level_1"/>
                        <field name="categ_id_level_2"/>
                        <field name="categ_id_level_3"/>
                        <field name="categ_id_level_4"/>
                        <field name="categ_id_level_5"/>
                        <field name="user_id"/>
                        <field name="processed"/>
                        <field name="menu_type"/>
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- # Root menu -->
    <menuitem id="menu_master_data_root" name="Master Data" sequence="1" web_icon="ttb_product,static/description/icon.png"/>
    <menuitem id="menu_master_data_root_mch" name="Xác nhận MCH" parent="menu_master_data_root"/>

    <!-- Các menu xác nhận MCH theo cơ sở -->
