<odoo>
    <record id="product_mch_setter2_list" model="ir.ui.view">
        <field name="name">product.mch.setter2.list</field>
        <field name="model">product.mch.setter2</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_id"/>
                <field name="default_code"/>
                <field name="list_price" optional="show"/>
                <field name="branch_id" optional="show"/>
                <field name="categ_id_level_1"/>
                <field name="categ_id_level_2"/>
                <field name="categ_id_level_3"/>
                <field name="categ_id_level_4"/>
                <field name="categ_id_level_5"/>
                <field name="user_id"/>
                <field name="processed"/>
                <!-- <field name="menu_type" optional="show"/> -->
            </list>
        </field>
    </record>

    <record id="product_mch_setter2_form" model="ir.ui.view">
        <field name="name">product.mch.setter2.list</field>
        <field name="model">product.mch.setter2</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_processed_and_next" type="object" string="Xác nhận" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="default_code" readonly="1"/>
                        <field name="list_price" optional="show" readonly="1"/>
                        <field name="branch_id" optional="show"/>
                        <field name="categ_id_level_1"/>
                        <field name="categ_id_level_2"/>
                        <field name="categ_id_level_3"/>
                        <field name="categ_id_level_4"/>
                        <field name="categ_id_level_5"/>
                        <field name="user_id"/>
                        <field name="processed"/>
                        <!-- <field name="menu_type"/> -->
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <menuitem id="menu_master_data_root2" name="Master Data 2" sequence="2" web_icon="ttb_product,static/description/icon.png"/>
    
    <!-- Danh sách sản phẩm 2 -->
    <record id="action_mch_setter2_branch_all" model="ir.actions.act_window">
        <field name="name">Xác nhận MCH</field>
        <field name="res_model">product.mch.setter2</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_master_data_root_mch2" name="Xác nhận MCH 2" parent="menu_master_data_root2" action="action_mch_setter2_branch_all" sequence="200"/>

    <record id="action_product_category2" model="ir.actions.act_window">
        <field name="name">MCH</field>
        <field name="res_model">product.category2</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_master_product_category2" name="MCH" parent="menu_master_data_root2" action="action_product_category2" sequence="300"/>
</odoo>