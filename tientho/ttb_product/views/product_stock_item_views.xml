<odoo>
    <record id="view_product_stock_item_list" model="ir.ui.view">
        <field name="name">product.stock.item.list</field>
        <field name="model">product.stock.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="price"/>
                <field name="qty_available"/>
            </list>
        </field>
    </record>

    <record id="view_product_stock_item_form" model="ir.ui.view">
        <field name="name">product.stock.item.form</field>
        <field name="model">product.stock.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>

                        <field name="category_id_level_1"/>
                        <field name="category_id_level_2"/>
                        <field name="category_id_level_3"/>
                        <field name="category_id_level_4"/>
                        <field name="category_id_level_5"/>
                        
                        <field name="price"/>
                        <field name="qty_available"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_stock_item" model="ir.actions.act_window">
        <field name="name">Sản phẩm tồn kho gốc</field>
        <field name="res_model">product.stock.item</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>