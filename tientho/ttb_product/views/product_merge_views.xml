<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_product_merge_list" model="ir.ui.view">
        <field name="name">product.merge.tree</field>
        <field name="model">product.merge</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_a_id"/>
                <field name="barcode_a"/>
                <field name="product_b_id"/>
                <field name="barcode_b"/>
                <field name="state"/>
                <field name="date_merge"/>
            </list>
        </field>
    </record>
    <record id="view_product_merge_form" model="ir.ui.view">
        <field name="name">product.merge.form</field>
        <field name="model">product.merge</field>
        <field name="arch" type="xml">
            <form string="Product Merge">
                <header>
                    <button name="action_merge" string="Ghép sản phẩm" type="object" class="btn-primary" invisible="state != 'new'" confirm="Bạn có chắc chắn gộp sản phẩm mà bạn đã chọn?"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="product_a_id" options="{'no_create': True}" readonly="state != 'new'"/>
                        <field name="barcode_a" readonly="1"/>
                        <field name="default_code_a" readonly="1"/>
                    </group>
                    <group>
                        <field name="product_b_id" options="{'no_create': True}" readonly="state != 'new'"/>
                        <field name="barcode_b" readonly="1"/>
                        <field name="default_code_b" readonly="1"/>
                    </group>
                    <group>
                        <field name="state" readonly="1"/>
                        <field name="date_merge" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Chi tiết các bản ghi khi bị tác động">
                            <field name="merge_detail_id">
                                <list create="0" delete="0" editable="top">
                                    <field name="merge_type"/>
                                    <field name="target_model"/>
                                    <field name="record_id"/>
                                    <field name="update_field"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                    <field name="extra_info"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_product_merge" model="ir.actions.act_window">
        <field name="name">Ghép sản phẩm</field>
        <field name="res_model">product.merge</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_product_merge" name="Ghép sản phẩm" parent="point_of_sale.menu_point_root" action="action_product_merge" sequence="10" />
</odoo>
