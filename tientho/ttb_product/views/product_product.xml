    <record id="product_product_inherit_list_view" model="ir.ui.view">
        <field name="name">product.product.inherit.list.view</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="top_supplier_id"/>
                <field name="top_supplier_price"/>
                <field name="top_supplier_date_start"/>
                <field name="top_supplier_date_end"/>
                <field name="season_type_id"/>
                <field name="active"/>
                <field name="sale_ok"/>
                <field name="purchase_ok"/>
            </xpath>
        </field>
