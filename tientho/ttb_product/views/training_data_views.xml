<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list View -->
    <record id="product_product_category_training_list_view" model="ir.ui.view">
        <field name="name">product.product.category.training.list</field>
        <field name="model">product.product.category.training</field>
        <field name="arch" type="xml">
            <list>
                <field name="category_id_level_1"/>
                <field name="category_id_level_2"/>
                <field name="category_id_level_3"/>
                <field name="category_id_level_4"/>
                <field name="category_id_level_5"/>
                <field name="product_name"/>
                <field name="is_processed"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="product_product_category_training_form_view" model="ir.ui.view">
        <field name="name">product.product.category.training.form</field>
        <field name="model">product.product.category.training</field>
        <field name="arch" type="xml">
            <form string="Training Data">
                <sheet>
                    <group>
                        <field name="category_id_level_1"/>
                        <field name="category_id_level_2"/>
                        <field name="category_id_level_3"/>
                        <field name="category_id_level_4"/>
                        <field name="category_id_level_5"/>
                        <field name="product_name"/>
                        <field name="is_processed"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- list View -->
    <record id="product_category_training_list_view" model="ir.ui.view">
        <field name="name">product.category.training.list</field>
        <field name="model">product.category.training</field>
        <field name="arch" type="xml">
            <list>
                <field name="category_code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="product_category_training_form_view" model="ir.ui.view">
        <field name="name">product.category.training.form</field>
        <field name="model">product.category.training</field>
        <field name="arch" type="xml">
            <form string="Training Data">
                <sheet>
                    <group>
                        <field name="parent_id"/>
                        <field name="category_code"/>
                        <field name="name"/>
                        <field name="keyword_count"/>
                    </group>
                    <notebook>
                        <page string="Từ khoá" name="keywords">
                            <field name="keyword_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="score"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="product_product_category_training_search_view" model="ir.ui.view">
        <field name="name">product.product.category.training.search</field>
        <field name="model">product.product.category.training</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_name"/>
                <field name="category_name" string="Tên danh mục"/>
                <filter string="Chưa xử lý" name="unprocessed" domain="[('is_processed', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Tên danh mục" name="group_by_category" context="{'group_by': 'category_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="product_product_category_training_action" model="ir.actions.act_window">
        <field name="name">Dữ liệu huấn luyện Phân loại</field>
        <field name="res_model">product.product.category.training</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="product_category_training_action" model="ir.actions.act_window">
        <field name="name">Dữ liệu danh mục</field>
        <field name="res_model">product.category.training</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="product_category_keyword_action" model="ir.actions.act_window">
        <field name="name">Dữ liệu từ khoá</field>
        <field name="res_model">product.category.keyword</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item -->

    <menuitem
        id="product_product_category_training_menu_root"
        name="Sản phẩm - Danh mục"
        parent="menu_product_matching_root"
        sequence="99"/>

    <menuitem
        id="product_product_category_training_menu_category"
        name="Danh mục"
        parent="product_product_category_training_menu_root"
        action="product_category_training_action"
        sequence="99"/>

    <menuitem
        id="product_category_keyword_menu"
        name="Từ khoá"
        parent="product_product_category_training_menu_root"
        action="product_category_keyword_action"
        sequence="99"/>

    <menuitem
        id="product_product_category_training_menu"
        name="Sản phẩm huấn luyện"
        parent="product_product_category_training_menu_root"
        action="product_product_category_training_action"
        sequence="99"/>

</odoo>
