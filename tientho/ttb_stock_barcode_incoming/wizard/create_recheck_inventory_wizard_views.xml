<odoo>
    <record id="view_inventory_recheck_wizard_form" model="ir.ui.view">
        <field name="name">inventory.recheck.wizard.form</field>
        <field name="model">create.recheck.inventory.wizard</field>
        <field name="arch" type="xml">
            <form string="Tạo phiếu kiểm kê lại">
                <group>
<!--                    <field name="period_inventory_id" placeholder="Chọn đợt kiểm kê"/>-->
                    <field name="reason" placeholder="Nhập lý do tạo phiếu (tùy chọn)"/>
                </group>
                <footer>
                    <button string="Xác nhận"
                            type="object"
                            name="action_confirm_recheck"
                            confirm="Bạn có chắc chắn muốn tạo phiếu kiểm kê lại?, hành động này không thể hoàn tác.Các phiếu kiểm kê liên quan sẽ bị HỦY."
                    />
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_inventory_recheck_wizard" model="ir.actions.act_window">
        <field name="name">Tạo phiếu kiểm kê lại</field>
        <field name="res_model">create.recheck.inventory.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
