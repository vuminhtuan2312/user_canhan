<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shelf_location_tree" model="ir.ui.view">
        <field name="name">shelf.location.tree</field>
        <field name="model">shelf.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="picking_type_id"/>
                <field name="mch_category_id"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_shelf_location_form" model="ir.ui.view">
        <field name="name">shelf.location.form</field>
        <field name="model">shelf.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="picking_type_id"/>
                        <field name="mch_category_id"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_shelf_location" model="ir.actions.act_window">
        <field name="name">Quầy kệ</field>
        <field name="res_model">shelf.location</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_shelf_location"
          name="Danh sách zone cho từng cơ sở"
          action="action_shelf_location"
          parent="ttb_stock_barcode_incoming.menu_kiem_ke_configuration_root"
          sequence="100"/>
</odoo>