<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Pivot view cho Báo cáo Tổng hợp KVC (dựa trên dòng báo cáo chi tiết) -->
    <record id="view_kvc_inventory_pivot" model="ir.ui.view">
        <field name="name">kvc.inventory.report.branch.line.pivot</field>
        <field name="model">kvc.inventory.report.branch.line</field>
        <field name="arch" type="xml">
            <pivot string="Báo cáo Tổng hợp KVC - Pivot">
                <!-- Rows: MCH2 then Product -->
                <field name="mch2" type="row"/>
                <field name="product_id" type="row"/>

                <!-- Columns: Warehouse/Cơ sở -->
                <field name="warehouse_id" type="col"/>

                <!-- Measures: Tiền chênh lệch (amount_diff) -->
                <field name="amount_diff" type="measure" operator="sum"/>

                <!-- Thêm một view mặc định để hiển thị theo cấu hình yêu cầu -->
            </pivot>
        </field>
    </record>
    <record id="action_kvc_inventory_report_branch_line_pivot" model="ir.actions.act_window">
        <field name="name">Báo cáo Tổng hợp KVC - Pivot</field>
        <field name="res_model">kvc.inventory.report.branch.line</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_kvc_inventory_pivot"/>
    </record>
</odoo>
