<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_period_inventory_tree" model="ir.ui.view">
        <field name="name">period.inventory.tree</field>
        <field name="model">period.inventory</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_period_inventory_form" model="ir.ui.view">
        <field name="name">period.inventory.form</field>
        <field name="model">period.inventory</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="action_start" string="Bắt đầu" type="object" invisible="state != 'draft'" class="btn-secondary"/>
                    <button name="action_done" string="Hoàn thành" type="object" invisible="state != 'in_progress'" class="btn-primary"/>
                    <button name="action_set_draft" string="Quay về nháp" type="object" invisible="state not in ['done', 'cancel']" class="btn-success"/>
                    <button name="action_cancel" string="Hủy" type="object" class="btn-danger"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="state != 'draft'"/>
                            <field name="code"/>
                            <field name="is_full_recheck_inventory"/>
                        </group>
                        <group>
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date" readonly="state != 'draft'"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Đợt kiểm kê theo cơ sở">
                            <field name="branch_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="branch_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Đồng bộ tồn kho Augges">
                            <field name="inventory_augges_stock_sync_ids">
                                <list editable="bottom">
                                    <field name="product_aug_id"/>
                                    <field name="kho_id"/>
                                    <field name="mch2"/>
                                    <field name="has_mch2"/>
                                    <field name="is_inventoried"/>
                                </list>
                            </field>
                        </page><page string="Phiên kiểm kê MCH2">
                            <field name="inventory_mch2_session_ids">
                                <list editable="bottom">
                                    <field name="mch2"/>
                                    <field name="state"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_period_inventory" model="ir.actions.act_window">
        <field name="name">Đợt kiểm kê</field>
        <field name="res_model">period.inventory</field>
        <field name="view_mode">list,form</field>
    </record>
