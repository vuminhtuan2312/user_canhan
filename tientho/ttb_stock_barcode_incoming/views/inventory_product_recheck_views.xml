<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventory_product_recheck_tree" model="ir.ui.view">
        <field name="name">inventory.product.recheck.tree</field>
        <field name="model">inventory.product.recheck</field>
        <field name="arch" type="xml">
            <list>
                <field name="barcode"/>
                <field name="branch_id"/>
                <field name="product_id"/>
            </list>
        </field>
    </record>
    <record id="view_inventory_product_recheck_form" model="ir.ui.view">
        <field name="name">inventory.product.recheck.form</field>
        <field name="model">inventory.product.recheck</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="barcode"/>
                        <field name="branch_id"/>
                        <field name="product_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_inventory_product_recheck" model="ir.actions.act_window">
        <field name="name">Ưu tien hậu kiểm</field>
        <field name="res_model">inventory.product.recheck</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_inventory_product_recheck"
          name="Ưu tiên hậu kiểm"
          action="action_inventory_product_recheck"
          parent="stock.menu_stock_config_settings"
          sequence="99"/>
</odoo>
