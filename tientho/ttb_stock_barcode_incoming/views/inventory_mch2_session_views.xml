<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_inventory_mch2_session_form" model="ir.ui.view">
        <field name="name">inventory.mch2.session.form</field>
        <field name="model">inventory.mch2.session</field>
        <field name="arch" type="xml">
            <form string="Phiên kiểm kê MCH2">
                <sheet>
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,open,done"/>
                    </header>
                    <group>
                        <group>
                            <field name="inventory_id"/>
                            <field name="mch2"/>
                            <field name="inventory_id"/>
                        </group>
                        <group>
                            <field name="start_time"/>
                            <field name="end_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết">
                            <field name="phieu_kk_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="mch_category_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Danh sách phiếu hậu kiểm 1">
                            <field name="hk1_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="mch_category_id"/>
                                </list>
                            </field>
                        </page><page string="Phiếu hậu kiểm A (sản phẩm chưa kiểm kê)">
                            <field name="hk_a_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="mch_category_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_inventory_mch2_session_tree" model="ir.ui.view">
        <field name="name">inventory.mch2.session.tree</field>
        <field name="model">inventory.mch2.session</field>
        <field name="arch" type="xml">
            <list string="Phiên kiểm kê MCH2">
                <field name="state"/>
                <field name="inventory_id"/>
            </list>
        </field>
    </record>
    <record id="action_inventory_mch2_session" model="ir.actions.act_window">
        <field name="name">Phiên kiểm kê MCH2</field>
        <field name="res_model">inventory.mch2.session</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_inventory_mch2_session_tree"/>
    </record>
</odoo>