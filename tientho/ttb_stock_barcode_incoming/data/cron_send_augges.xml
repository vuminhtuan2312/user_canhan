    <record id="cron_auto_create_reports" model="ir.cron">
        <field name="name">Tự động sinh Báo cáo Tổng hợp</field>
        <field name="model_id" ref="model_period_inventory"/>
        <field name="state">code</field>
        <field name="code">model.cron_auto_create_reports()</field>
        <field name="active" eval="True"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- Run daily at 07:00; Python code will check weekday and only execute on Wednesday. -->
        <field name="nextcall" eval="(DateTime.now().replace(hour=0, minute=0, second=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')" />
    </record>
</odoo>
