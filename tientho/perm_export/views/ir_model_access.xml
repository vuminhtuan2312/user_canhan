<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="vps_ir_access_view_form" model="ir.ui.view">
        <field name="name">vps_ir_access_view_form</field>
        <field name="model">ir.model.access</field>
        <field name="inherit_id" ref="base.ir_access_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='perm_unlink']" position="after">
                <field name="perm_export"/>
            </xpath>
        </field>
    </record>
    <record id="vps_ir_access_view_tree" model="ir.ui.view">
        <field name="name">vps_ir_access_view_tree</field>
        <field name="model">ir.model.access</field>
        <field name="inherit_id" ref="base.ir_access_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='perm_unlink']" position="after">
                <field name="perm_export"/>
            </xpath>
        </field>
    </record>
    <record id="vps_ir_access_view_tree_edition" model="ir.ui.view">
        <field name="name">vps_ir_access_view_tree_edition</field>
        <field name="model">ir.model.access</field>
        <field name="inherit_id" ref="base.ir_access_view_tree_edition"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='perm_unlink']" position="after">
                <field name="perm_export"/>
            </xpath>
        </field>
    </record>

</odoo>
