<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_ttb_label_wizard" model="ir.actions.report">
        <field name="name">In Tem Nhãn (Mẫu TTB)</field>
        <field name="model">product.label.layout</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ttb_price_change_request.report_ttb_label_wizard_template</field>
        <field name="report_file">ttb_price_change_request.report_ttb_label_wizard_template</field>
        <field name="print_report_name">'Tem_San_Pham'</field>
        <field name="binding_model_id" ref="product.model_product_label_layout"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_ttb_label_fixed_3col"/>
    </record>

    <template id="report_ttb_label_wizard_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <div style="width: 100%; overflow: hidden;">

                            <t t-set="items_to_print" t-value="[]"/>

                            <t t-if="wizard.picking_ids">
                                <t t-foreach="wizard.picking_ids.move_ids" t-as="move">
                                    <t t-set="qty_val" t-value="move.quantity if move.quantity else move.product_uom_qty"/>
                                    <t t-set="items_to_print" t-value="items_to_print + [(move.product_id, int(qty_val))]"/>
                                </t>
                            </t>

                            <t t-else="">
                                <t t-set="products" t-value="wizard.product_ids if wizard.product_ids else wizard.product_tmpl_ids"/>
                                <t t-foreach="products" t-as="product">
                                    <t t-set="items_to_print" t-value="items_to_print + [(product, int(wizard.custom_quantity))]"/>
                                </t>
                            </t>

                            <t t-foreach="items_to_print" t-as="item">
                                <t t-set="product" t-value="item[0]"/>
                                <t t-set="print_qty" t-value="item[1]"/>

                                <t t-foreach="range(print_qty)" t-as="i">
                                    <div style="float: left; width: 31%; padding: 10px; box-sizing: border-box; page-break-inside: avoid;">
                                        <div style="border: 2px solid #000; padding: 5px; text-align: center; height: 180px; position: relative; background-color: #fff; font-family: 'Arial', sans-serif;">

                                            <div style="height: 60px; overflow: hidden; font-weight: bold; font-size: 15px; line-height: 1.3; text-align: left; color: #000;">
                                                <span t-field="product.name"/>
                                            </div>

                                            <t t-set="price_val" t-value="wizard.get_augges_price(product)"/>

<!--                                            <t t-if="wizard.pricelist_id">-->
<!--                                                <t t-set="price_val" t-value="wizard.pricelist_id._get_product_price(product, 1.0)"/>-->
<!--                                            </t>-->
<!--                                            <t t-else="">-->
<!--                                                <t t-set="price_val" t-value="product.lst_price if product._name == 'product.product' else product.list_price"/>-->
<!--                                            </t>-->

                                            <div style="margin-bottom: 5px; line-height: 1; white-space: nowrap;">
                                                <span style="font-size: 14px; vertical-align: baseline; margin-right: 3px;">GIÁ:</span>
                                                <span t-esc="price_val" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 0}" style="font-size: 28px; font-weight: 900; color: #000;"/>
                                                <span style="font-size: 11px; vertical-align: top; margin-left: 5px; position: relative; top: 2px;">VND</span>
                                            </div>

                                            <t t-set="barcode_val" t-value="wizard.get_barcode_to_print(product)"/>

                                            <div style="width: 100%; text-align: center; margin-bottom: 5px;">
                                                <t t-if="barcode_val">
                                                    <img t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', barcode_val, 600, 40)" style="width: 100%; height: 30px; display: block; margin: 0 auto;"/>
                                                    <div style="font-size: 14px; margin-top: 2px;">
                                                        <span t-esc="barcode_val"/>
                                                    </div>
                                                </t>
                                                <t t-else="">
                                                    <div style="height: 30px; line-height: 30px; color: red; font-size: 10px; border: 1px dashed red;">
                                                        NO BARCODE
                                                    </div>
                                                </t>
                                            </div>

                                            <div style="position: absolute; bottom: 5px; left: 0; width: 100%; padding: 0 8px;">
                                                <div style="float: left; font-size: 12px; color: #000;">
                                                    <span t-if="product.uom_id">
                                                        <span t-field="product.uom_id.name"/>
                                                    </span>
                                                </div>
                                                <div style="float: right; font-size: 12px; color: #000;">
                                                    <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>