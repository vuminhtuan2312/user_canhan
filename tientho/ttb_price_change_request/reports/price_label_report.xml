<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_ttb_label_fixed_3col" model="report.paperformat">
        <field name="name">TTB Label Fixed</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_ttb_label_print" model="ir.actions.report">
        <field name="name">In Tem Nhãn</field>
        <field name="model">ttb.label.print.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ttb_price_change_request.report_ttb_label_template</field>
        <field name="report_file">ttb_price_change_request.report_ttb_label_template</field>
        <field name="print_report_name">'Tem_' + object.name</field>
        <field name="binding_model_id" ref="model_ttb_label_print_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_ttb_label_fixed_3col"/>
    </record>

    <template id="report_ttb_label_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">

                        <div style="width: 100%; overflow: hidden;">

                            <t t-set="all_lines" t-value="o.line_a_ids"/>

                            <t t-foreach="all_lines" t-as="line">
                                <t t-foreach="range(int(line.qty) if line.qty else 1)" t-as="i">

                                    <div style="float: left; width: 31%; padding: 10px; box-sizing: border-box; page-break-inside: avoid;">

                                        <div style="border: 2px solid #000; padding: 5px; text-align: center; height: 180px; position: relative; background-color: #fff; font-family: 'Arial', sans-serif;">

                                            <div style="height: 60px; overflow: hidden; font-weight: bold; font-size: 15px; line-height: 1.3; text-align: left; color: #000;">
                                                <span t-field="line.product_name"/>
                                            </div>

                                            <div style="margin-bottom: 5px; line-height: 1; white-space: nowrap;">
                                                <span style="font-size: 14px; vertical-align: baseline; margin-right: 3px;">GIÁ:</span>
                                                <span t-field="line.new_price"
                                                      t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 0}"
                                                      style="font-size: 28px; font-weight: 900; color: #000;"/>
                                                <span style="font-size: 11px; vertical-align: top; margin-left: 5px; position: relative; top: 2px;">VND</span>
                                            </div>

                                            <t t-set="barcode_val" t-value="line.get_barcode_to_print(product)"/>

                                            <div style="width: 100%; text-align: center; margin-bottom: 5px;">
                                                <t t-if="barcode_val">
                                                    <img t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', barcode_val, 600, 40)" style="width: 100%; height: 30px; display: block; margin: 0 auto;"/>

                                                    <div style="font-size: 14px; margin-top: 2px;">
                                                        <span t-esc="barcode_val"/>
                                                    </div>
                                                </t>
                                                <t t-else="">
                                                    <div style="height: 30px; line-height: 30px; color: red; font-size: 10px; border: 1px dashed red;">
                                                        NO BARCODE
                                                    </div>
                                                </t>
                                            </div>

                                            <div style="position: absolute; bottom: 0px; left: 0; width: 100%; padding: 0 8px;">

                                                <div style="float: left; font-size: 12px; color: #000;">
                                                    <span t-if="line.product_id and line.product_id.uom_id">
                                                        <span t-field="line.product_id.uom_id.name"/>
                                                    </span>
                                                </div>

                                                <div style="float: right; font-size: 12px; color: #000;">
                                                    <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
                                                </div>

                                            </div>

                                        </div>
                                    </div>

                                </t>
                            </t>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>