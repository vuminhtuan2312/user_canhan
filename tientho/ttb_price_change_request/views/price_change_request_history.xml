<odoo>
    <!-- Tree/List -->
    <record id="view_ttb_pcr_update_history_tree" model="ir.ui.view">
        <field name="name">ttb.pcr.update.history.tree</field>
        <field name="model">ttb.pcr.update.history</field>
        <field name="arch" type="xml">
            <list string="Lịch sử cập nhật giá Augges" create="false" edit="false" delete="false">
                <field name="updated_at"/>
                <field name="request_id"/>
                <field name="product_id"/>
                <field name="augges_id"/>
                <field name="price_level"/>
                <field name="old_value"/>
                <field name="new_value"/>
                <field name="updated_value"/>
                <field name="state"/>
                <field name="updated_by"/>
                <field name="message" optional="show"/>
            </list>
        </field>
    </record>


    <!-- Action -->
    <record id="action_ttb_pcr_update_history" model="ir.actions.act_window">
        <field name="name">Lịch sử cập nhật Augges</field>
        <field name="res_model">ttb.pcr.update.history</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_ttb_pcr_update_history_tree"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có dữ liệu lịch sử.
            </p>
            <p>Lịch sử sẽ được ghi nhận khi phiếu thay đổi giá cập nhật xuống Augges và thực hiện kiểm tra đối chiếu.
            </p>
        </field>
    </record>

    <!-- Menu: đặt dưới menu của module PCR nếu bạn đã có -->
    <menuitem id="menu_ttb_pcr_update_history"
              name="Lịch sử cập nhật Augges"
              parent="menu_ttb_price_change_root"
              action="action_ttb_pcr_update_history"
              sequence="90"/>
</odoo>
