        <field name="domain_force">[('ttb_branch_id', 'in', user.ttb_branch_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="kvc_inventory_session_rule_user" model="ir.rule">
        <field name="name">Xem phiên kiểm theo cơ sở</field>
        <field name="model_id" ref="model_kvc_inventory_session"/>
        <field name="domain_force">[('branch_id', 'in', user.ttb_branch_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="stock_check_sgk_book_rule_user" model="ir.rule">
        <field name="name">Xem phiên kiểm theo cơ sở</field>
        <field name="model_id" ref="model_stock_check_sgk_book"/>
        <field name="domain_force">[('branch_id', 'in', user.ttb_branch_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="sgk_book_rule_admin" model="ir.rule">
        <field name="name">Admin thấy toàn bộ phiên kiểm</field>
        <field name="model_id" ref="model_sgk_book"/>
        <field name="domain_force">[]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>