<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="stock_check_session_rule_user" model="ir.rule">
        <field name="name">Xem phiên kiểm theo cơ sở</field>
        <field name="model_id" ref="model_stock_check_session"/>
        <field name="domain_force">[('branch_id', 'in', user.ttb_branch_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="stock_check_session_rule_admin" model="ir.rule">
        <field name="name">Admin thấy toàn bộ phiên kiểm</field>
        <field name="model_id" ref="model_stock_check_session"/>
        <field name="domain_force">[]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="sgk_book_rule_user" model="ir.rule">
        <field name="name">Xem phiên kiểm theo cơ sở</field>
