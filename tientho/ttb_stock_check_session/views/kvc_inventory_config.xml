<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_kvc_inventory_config_form" model="ir.ui.view">
        <field name="name">kvc.inventory.config.form</field>
        <field name="model">kvc.inventory.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id" />
                    </group>
                    <notebook>
                        <page string="Danh sách sản phẩm">
                            <field name="product_line_ids">
                                <list editable="bottom">
                                    <field name="product_sector"/>
                                    <field name="product_code"/>
                                    <field name="product_code_1"/>
                                    <field name="barcode"/>
                                    <field name="barcode_k"/>
                                    <field name="product_name"/>
                                    <field name="uom"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_kvc_inventory_config_list" model="ir.ui.view">
        <field name="name">kvc.inventory.config.list</field>
        <field name="model">kvc.inventory.config</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="branch_id" />
            </list>
        </field>
    </record>
    <record id="action_kvc_inventory_config" model="ir.actions.act_window">
        <field name="name">Cấu hình sản phẩm</field>
        <field name="res_model">kvc.inventory.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>