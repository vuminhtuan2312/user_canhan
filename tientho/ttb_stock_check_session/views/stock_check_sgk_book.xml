<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_stock_check_sgk_book_form" model="ir.ui.view">
        <field name="name">stock.check.sgk.book.form</field>
        <field name="model">stock.check.sgk.book</field>
        <field name="arch" type="xml">
            <form create="0">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="user_id"/>
                        <field name="product_id" />
                        <field name="branch_id" readonly="1"/>
                        <field name="user_by" readonly="1"/>
                        <field name="done_date" />
                        <field name="create_date" />
                        <field name="note" />
                    </group>
                    <notebook>
                        <page string="Danh sách sản phẩm">
                            <field name="line_ids">
                                <kanban create="False" limit="2000" can_open="0">
                                    <field name="product_id"/>
                                    <field name="barcode"/>
                                    <field name="qty_real"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_card">
                                                <div>
                                                    <strong><field name="product_id"/></strong>
                                                </div>
                                                <div>
                                                    <span>Mã vạch: <field name="barcode"/></span>
                                                </div>
                                                <div>
                                                    <span>Mã nhà cung cấp: <field name="code_ncc"/></span>
                                                </div>
                                                <div>
                                                    <span>Mã tham chiếu: <field name="reference_code"/></span>
                                                </div>
                                                <div>
                                                    <span>Mã vạch K: <field name="barcode_k"/></span>
                                                </div>
                                                <div>
                                                    <span>Thực tế: <field name="qty_real" /></span>
                                                </div>
                                                <div>
                                                    <span>Số luợng bổ sung: <field name="last_qty_add"/></span>
                                                </div>
                                                <div>
                                                    <span>Trạng thái kiểm: <field name="state_check" /></span>
                                                </div>
                                                <div>
                                                    <span><field name="image_1920" widget="image" class="oe_avatar"/></span>
                                                </div>
                                                <div>
                                                    <button type="object" name="open_check_wizard" class="btn btn-primary btn-sm mt-2" invisible="state == 'done'">Kiểm tồn</button>
                                                    <button name="open_add_qty_wizard" type="object" class="btn btn-primary btn-sm mt-2" invisible="state == 'draft' or can_check_inventory == False">Nhập bổ sung</button>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                    <div>
                        <button name="action_mark_done" type="object" string="Hoàn thành" class="oe_highlight mt-2" invisible="state == 'done'"/>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_stock_check_sgk_book_list" model="ir.ui.view">
        <field name="name">stock.check.sgk.book.list</field>
        <field name="model">stock.check.sgk.book</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="name" />
                <field name="branch_id" />
                <field name="product_id" />
                <field name="create_date" />
                <field name="user_by" />
                <field name="state" />
                <field name="done_date" />
            </list>
        </field>
    </record>
    <record id="action_stock_check_sgk_book" model="ir.actions.act_window">
        <field name="name">Kiểm tồn sách giáo khoa</field>
        <field name="res_model">stock.check.sgk.book</field>
        <field name="view_mode">list,form,pivot</field>
    </record>
</odoo>