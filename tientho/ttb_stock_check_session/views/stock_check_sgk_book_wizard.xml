<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="stock_check_sgk_book_wizard_form" model="ir.ui.view">
        <field name="name">stock.check.sgk.book.wizard.form</field>
        <field name="model">stock.check.sgk.book.wizard</field>
        <field name="arch" type="xml">
              <form string="Cập nhật tồn thực tế">
                  <group>
                      <field name="qty_real"/>
                  </group>
                  <footer>
                      <button name="action_confirm" string="Cập nhật" type="object" class="btn-primary"/>
                      <button string="Hủy" special="cancel" class="btn-secondary"/>
                  </footer>
              </form>
        </field>
    </record>
    <record id="action_stock_check_sgk_book_wizard" model="ir.actions.act_window">
        <field name="name">Cập nhật tồn</field>
        <field name="res_model">stock.check.sgk.book.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>