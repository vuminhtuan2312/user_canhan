<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="add_qty_sgk_book_wizard_form" model="ir.ui.view">
        <field name="name">add.qty.sgk.book.wizard.form</field>
        <field name="model">add.qty.sgk.book.wizard</field>
        <field name="arch" type="xml">
              <form string="Cập nhật tồn bổ sung">
                  <group>
                      <field name="qty_add"/>
                  </group>
                  <footer>
                      <button name="action_add_qty" string="Cập nhật" type="object" class="btn-primary"/>
                      <button string="Hủy" special="cancel" class="btn-secondary"/>
                  </footer>
              </form>
        </field>
    </record>
    <record id="action_add_qty_sgk_book_wizard" model="ir.actions.act_window">
        <field name="name">Cập nhật bổ sung</field>
        <field name="res_model">add.qty.sgk.book.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>