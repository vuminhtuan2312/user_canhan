<odoo>
    <data noupdate="1">
        <record id="seq_stock_check_session" model="ir.sequence">
            <field name="name">Mã phiên kiểm tồn</field>
            <field name="code">stock.check.session</field>
            <field name="prefix">PKT-%(day)s-%(month)s-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <record id="seq_sgk_book" model="ir.sequence">
            <field name="name">Mã kiểm</field>
            <field name="code">sgk.book</field>
            <field name="prefix">PKT-%(day)s-%(month)s-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <record id="seq_kvc_inventory_session" model="ir.sequence">
            <field name="name">Mã kiểm</field>
            <field name="code">kvc.inventory.session</field>
            <field name="prefix">PKKVC-%(day)s-%(month)s-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <record id="seq_stock_check_sgk_book" model="ir.sequence">
            <field name="name">Mã kiểm</field>
            <field name="code">stock.check.sgk.book</field>
            <field name="prefix">SGK-%(day)s-%(month)s-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>
