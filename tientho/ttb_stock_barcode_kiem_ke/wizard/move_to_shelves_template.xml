<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="move_to_shelves_template_form" model="ir.ui.view">
        <field name="name">move.to.shelves.template.form</field>
        <field name="model">move.to.shelves.template</field>
        <field name="arch" type="xml">
            <form string="Chuyển lên quầy">
                <sheet>
                    <group>
                        <field name="stock_picking_id" invisible="1"/>
                        <field name="branch_ids" invisible="1"/>
                        <field name="branch_id" invisible="1"/>
                        <field name="warehouse_id" domain="['&amp;', ('ttb_branch_id', '=', branch_id), '|', ('name', 'ilike', 'KBL'), ('name', 'ilike', 'KVC')]"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Xác nhận" type="object"/>
                    <button name="cancel" string="Hủy" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>