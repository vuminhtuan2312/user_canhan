<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='do_print_picking']" position="before">
                <button name="action_move_to_shelves" string="Chuyển lên quầy" type="object"
                invisible="state != 'done' or picking_type_code != 'incoming'"/>
            </xpath>
            <xpath expr="//button[@name='do_print_picking']" position="attributes" >
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='period_inventory_id']" position="after">
                <field name="transfer_state" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='quantity']" position="after">
                <field name="remaining_transfer_quantity" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>