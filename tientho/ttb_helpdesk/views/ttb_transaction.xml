<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_transaction_view_form" model="ir.ui.view">
        <field name="name">ttb_transaction_view_form</field>
        <field name="model">ttb.transaction</field>
        <field name="arch" type="xml">
            <form class="o_helpdesk_ticket_crm">
                <header>
<!--                    <button name="action_create_ticket" type="object" class="oe_inline" string="tạo ticket"/>-->
                    <field name="state" widget="statusbar" options="{'clickable': True}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" force_save="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Thông tin khách hàng">
                            <field name="voip_call_id" invisible="1" force_save="1"/>
                            <field name="id" invisible="1"/>
                            <field name="partner_phone"/>
                            <label for="partner_name"/>
                            <div class="o_row">
                                <field name="partner_name" readonly="partner_id" force_save="1"/>
                                <button name="action_view_partner" type="object" string="Xem" class="btn-link mb-1 px-0" invisible="not partner_id" context="{'cancelsave': True, 'partner_id_on_view': partner_id}"/>
                            </div>

                            <field name="partner_id" class="field_partner_id" widget="res_partner_many2one" context="{'default_phone': partner_phone}" invisible="1"/>
                            <field name="ttb_branch_id" options="{'no_create': True}"/>
                            <field name="related_department_ids" widget="many2many_tags_unlimit" options="{'no_create': True}"/>
                        </group>
                        <group string="Nhân viên">
                            <field name="user_id" widget="many2one_avatar_user" options="{'no_create': True}"/>
                            <field name="department_id" string="Phòng ban" options="{'no_create': True}"/>
                            <field name="recording_link" widget="audio_link"  invisible="not recording_link or not id"/>
                            <button name="get_recording_link" type="object" string="Lấy file ghi âm" invisible="recording_link or not id or not voip_call_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Nội dung tương tác">
                            <field name="show_under_control_content" invisible="1"/>
                            <field name="show_out_control_content" invisible="1"/>
                            <field name="show_other_control_content" invisible="1"/>
                            <field name="source_channel"/>
                            <field name="ttb_description_ids" widget="many2many_checkboxes"/>
                            <field name="under_control_content_ids" string="Nội dung liên quan tư vấn trong tầm" widget="many2many_tags_unlimit" invisible="not show_under_control_content" required="show_under_control_content" options="{'no_create': True, 'no_edit': True, 'no_quick_create': True, 'no_open': True}"/>
                            <field name="out_control_content_ids" string="Nội dung liên quan tư vấn ngoài tầm" widget="many2many_tags_unlimit" invisible="not show_out_control_content" required="show_out_control_content" options="{'no_create': True, 'no_edit': True, 'no_quick_create': True, 'no_open': True}"/>
                            <field name="other_control_content_ids" widget="many2many_tags_unlimit" invisible="not show_other_control_content" required="show_other_control_content" options="{'no_create': True, 'no_edit': True, 'no_quick_create': True, 'no_open': True}"/>
                            <field name="partner_comment"/>
                            <field name="user_comment"/>
                            <field name="has_related_user"/>
                        </group>
                        <group string="Đơn hàng gần nhất">
                            <field name="last_order_name"/>
                            <field name="last_order_date"/>
                            <field name="last_order_account_move"/>
                            <field name="last_order_cashier"/>
                            <field name="last_order_amount_total"/>
                            <field name="last_order_line_ids" nolabel="1" options="{'no_open': True}">
                                <list>
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                </list>
                            </field>
                            <separator string="Thông tin đơn hàng"/>
                            <field name="order_ids" nolabel="1" />
                            <separator string="Lịch sử tuơng tác"/>
                            <field name="ttb_transaction_ids" nolabel="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <record id="ttb_transaction_view_tree" model="ir.ui.view">
        <field name="name">ttb_transaction_view_tree</field>
        <field name="model">ttb.transaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="ttb_branch_id" options="{'no_create': True}"/>
                <field name="source_channel"/>
                <field name="ttb_description"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="ttb_transaction_view_search" model="ir.ui.view">
        <field name="name">ttb_transaction_view_search</field>
        <field name="model">ttb.transaction</field>
        <field name="arch" type="xml">
            <search string="Happy Call">
                <field name="name" string="Tất cả" filter_domain="['|', '|', ('name', 'ilike', self), ('partner_name', 'ilike', self), ('partner_phone', 'ilike', self)]"/>
                <field name="partner_id" filter_domain="['|', ('partner_id', '=', self), ('partner_phone', '=', self)]"/>
                <field name="ttb_branch_id"/>
                <field name="user_id"/>
                <field name="last_order_name" />
                <group expand="1" string="Group By">
                    <filter string="Cơ sở" name="group_by_ttb_branch_id" context="{'group_by': 'ttb_branch_id'}"/>
                    <filter string="Trạng thái" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Nguồn call" name="group_by_source_channel" context="{'group_by': 'source_channel'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="ttb_transaction_action" model="ir.actions.act_window">
        <field name="name">Tương tác</field>
        <field name="res_model">ttb.transaction</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
