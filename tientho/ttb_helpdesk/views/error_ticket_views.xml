<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_error_ticket_list" model="ir.ui.view">
        <field name="name">error.ticket.list</field>
        <field name="model">error.ticket</field>
        <field name="arch" type="xml">
            <list string="Danh sách phiếu lỗi">
                <field name="ticket_code"/>
                <field name="ticket_name"/>
                <field name="deadline"/>
                <field name="handler_id"/>
                <field name="approver_id"/>
                <field name="deducted_points"/>
                <field name="related_score_ticket"/>
                <field name="store_name"/>
                <field name="address"/>
                <field name="store_manager"/>
                <field name="phone_number"/>
                <field name="branch_id"/>
                <field name="failed_criteria"/>
                <field name="violator_employee"/>
                <field name="criteria_group"/>
                <field name="processing_result"/>
            </list>
        </field>
    </record>
    <record id="view_error_ticket_form" model="ir.ui.view">
        <field name="name">error.ticket.form</field>
        <field name="model">error.ticket</field>
        <field name="arch" type="xml">
            <form string="Phiếu Lỗi">
                <sheet>
                    <group>
                        <group>
                            <field name="ticket_code" required="1"/>
                            <field name="ticket_name"/>
                        </group>
                        <group>
                            <field name="deadline"/>
                            <field name="deducted_points"/>
                        </group>
                        <group>
                            <field name="handler_id"/>
                            <field name="approver_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Thông tin cửa hàng">
                            <group>
                                <field name="store_name"/>
                                <field name="address"/>
                                <field name="store_manager"/>
                                <field name="phone_number"/>
                                <field name="branch_id"/>
                            </group>
                        </page>
                        <page string="Khác">
                            <group>
                                <field name="related_score_ticket"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_error_ticket" model="ir.actions.act_window">
        <field name="name">Phiếu Lỗi</field>
        <field name="res_model">error.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_error_ticket_list"/>
    </record>
</odoo>