<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="helpdesk_settings_view_form" model="ir.ui.view">
            <field name="name">helpdesk.settings.form</field>
            <field name="model">helpdesk.settings</field>
            <field name="arch" type="xml">
                <form string="Helpdesk Settings" create="false" edit="true" delete="false">
                    <sheet>
                        <group>
                            <field name="shopping_experience_note"/>
                            <field name="introduce_to_others_note"/>
                            <field name="improvement_suggestions_note"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="helpdesk_settings_action_server" model="ir.actions.server">
            <field name="name">Helpdesk Settings</field>
            <field name="model_id" ref="model_helpdesk_settings"/>
            <field name="state">code</field>
            <field name="code">action = model.find_or_create_and_open()</field>
        </record>

        <menuitem id="helpdesk_settings_menu"
                  name="Cấu hình câu hỏi"
                  parent="helpdesk.helpdesk_menu_config"
                  action="helpdesk_settings_action_server"
                  groups="ttb_kpi.group_ttb_kpi_tn_cskh,ttb_kpi.group_ttb_kpi_tnkh_manager"
                  sequence="10"/>
    </data>
</odoo>
