<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="ttb_region_view_tree" model="ir.ui.view">
        <field name="name">ttb_region_view_tree</field>
        <field name="model">ttb.region</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="director_id" widget="many2one_avatar_user" options="{'no_create': True}"/>
            </list>
        </field>
    </record>

    <record id="ttb_region_action" model="ir.actions.act_window">
        <field name="name">Vùng</field>
        <field name="res_model">ttb.region</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
