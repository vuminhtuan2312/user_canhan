<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_popup_filtered_hpc_view_form" model="ir.ui.view">
        <field name="name">ttb.popup.filtered.hpc.form</field>
        <field name="model">ttb.popup.filtered.hpc</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="branch_ids" widget="many2many_tags"/>
                            <field name="date_filter"/>
                        </group>
                        <group>
                            <field name="date_from" invisible="date_filter != 'custom'"/>
                            <field name="date_to" invisible="date_filter != 'custom'"/>
                            <field name="related_content_ids" widget="many2many_tags"/>
                            <field name="level"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Lọc" class="btn-primary" type="object" name="btn_apply_filters" data-hotkey="enter"/>
                    <button string="Hủy" class="btn-secondary" special="cancel" data-hotkey="z"/>
                    <button string="Tham số mặc định" class="btn-secondary ms-auto" type="object" name="btn_reset"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="ttb_popup_filtered_hpc_action" model="ir.actions.act_window">
        <field name="name">Lọc báo cáo CRM hpc</field>
        <field name="res_model">ttb.popup.filtered.hpc</field>
        <field name="view_mode">form</field>
    </record>

</odoo>
