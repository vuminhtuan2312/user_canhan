<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="wizard_coverage_week" model="ir.ui.view">
        <field name="name">wizard.coverage.week.form</field>
        <field name="model">wizard.coverage.week</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="branch" widget="many2many_tags"/>
                    <field name="categ_ids" widget="many2many_tags"/>
                    <field name="product_tag_ids" widget="many2many_tags"/>
                    <field name="date_range" />
                </group>
                <footer>
                    <button name="action_confirm" string="Xác nhận" type="object" class="btn-primary"/>
                    <button name="action_cancel" string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>