<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_report_pos_view_form" model="ir.ui.view">
        <field name="name">ttb.report.pos.action.form</field>
        <field name="model">ttb.report.pos.action</field>
        <field name="arch" type="xml">
            <form create="0">
                <header>
                    <button name="action_view_report_pos" type="object" class="btn-primary" string="Xem báo cáo">Xem báo cáo</button>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="branch_id" widget="many2many_tags" readonly="state_view_report != 'new'"/>
                            <field name="categ_id_level_1" readonly="state_view_report != 'new'"/>
                            <field name="categ_id_level_2" readonly="state_view_report != 'new'"/>
                            <field name="categ_id_level_3" readonly="state_view_report != 'new'"/>
                            <field name="categ_id_level_4" readonly="state_view_report != 'new'"/>
                            <field name="categ_id_level_5" readonly="state_view_report != 'new'"/>
                        </group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                            <field name="separate_playground_supermarket" />
                            <field name="merge_duplicate_products" />
                            <field name="supplier_ids" widget="many2many_tags" readonly="state_view_report != 'new'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Danh sách đã tạo PR">
                            <field name="purchase_request_ids" />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <record id="ttb_report_pos_view_list" model="ir.ui.view">
        <field name="name">ttb.report.pos.action.list</field>
        <field name="model">ttb.report.pos.action</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="branch_id" widget="many2many_tags"/>
                <field name="user_id" />
                <field name="date" />
                <field name="state" />
            </list>
        </field>
    </record>
    <record id="ttb_report_pos_action" model="ir.actions.act_window">
        <field name="name">Dự trù mua hàng</field>
        <field name="res_model">ttb.report.pos.action</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>