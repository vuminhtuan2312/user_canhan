<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="wizard_purchase_delivery" model="ir.ui.view">
        <field name="name">wizard.purchase.delivery.form</field>
        <field name="model">wizard.purchase.delivery</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="branch" widget="many2many_tags"/>
                    <field name="date_start" widget="daterange" options="{'end_date_field': 'date_end'}"/>
                    <field name="date_end" invisible="1"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Xác nhận" type="object" class="btn-primary"/>
                    <button name="action_cancel" string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>