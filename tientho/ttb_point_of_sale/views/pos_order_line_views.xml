<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_pos_order_form_inherit_khu_vuc" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.khu.vuc</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lines']/list/field[@name='product_id']" position="after">
                <field name="khu_vuc" string="Khu vực" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>

