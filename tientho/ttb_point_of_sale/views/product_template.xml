<?xml version="1.0" encoding="utf-8" ?>
<odoo>
      <record id="view_product_template_form_dup_tab" model="ir.ui.view">
          <field name="name">product.template.form.duplicate.tab</field>
          <field name="model">product.template</field>
          <field name="inherit_id" ref="product.product_template_only_form_view"/>
           <field name="arch" type="xml">
                <xpath expr="//sheet/notebook" position="inside">
                    <page string="Sản phẩm trùng mã hàng">
                        <group>
                            <field name="duplicate_product_ids" widget="many2many_tags"
                               placeholder="Chọn các sản phẩm trùng..."/>
                        </group>
                   </page>
                </xpath>
           </field>
      </record>
</odoo>