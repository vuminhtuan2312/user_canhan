<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="report_accumulate_points" model="account.report">
        <field name="name">Báo cáo khách hàng phát sinh tích điểm</field>
        <field name="filter_show_draft" eval="False"/>
        <field name="filter_account_type" eval="False"/>
        <field name="filter_partner" eval="False"/>
        <field name="filter_unfold_all" eval="True"/>
        <field name="filter_unreconciled" eval="False"/>
        <field name="filter_period_comparison" eval="False"/>
        <field name="filter_multi_company">selector</field>
        <field name="filter_hide_0_lines">never</field>
        <field name="default_opening_date_filter">this_month</field>
        <field name="search_bar" eval="True"/>
        <field name="load_more_limit" eval="200"/>
        <field name="custom_handler_model_id" ref="model_report_accumulate_points"/>
    </record>

    <record id="report_accumulate_points_action" model="ir.actions.client">
        <field name="name">Báo cáo khách hàng phát sinh tích điểm</field>
        <field name="tag">account_report</field>
        <field name="path">report-accumulate-points</field>
        <field name="context" eval="{'report_id': ref('ttb_point_of_sale.report_accumulate_points')}"/>
    </record>

    <record id="report_total_earned_spent_points" model="account.report">
        <field name="name">Báo cáo khách hàng tích tiêu điểm</field>
        <field name="filter_show_draft" eval="False"/>
        <field name="filter_account_type" eval="False"/>
        <field name="filter_partner" eval="False"/>
        <field name="filter_unfold_all" eval="True"/>
        <field name="filter_unreconciled" eval="False"/>
        <field name="filter_period_comparison" eval="False"/>
        <field name="filter_multi_company">selector</field>
        <field name="filter_hide_0_lines">never</field>
        <field name="default_opening_date_filter">this_month</field>
        <field name="search_bar" eval="True"/>
        <field name="load_more_limit" eval="200"/>
        <field name="custom_handler_model_id" ref="model_report_earned_spent_points"/>
    </record>

    <record id="report_total_earned_spent_points_action" model="ir.actions.client">
        <field name="name">Báo cáo khách hàng tích tiêu điểm</field>
        <field name="tag">account_report</field>
        <field name="path">report-earned-spent-points</field>
        <field name="context" eval="{'report_id': ref('ttb_point_of_sale.report_total_earned_spent_points')}"/>
    </record>
</odoo>
