<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- List view -->
    <record id="view_xuat_nhap_kho_augges_list" model="ir.ui.view">
        <field name="name">ttb.xuat.nhap.kho.augges.list</field>
        <field name="model">ttb.xuat.nhap.kho.augges</field>
        <field name="arch" type="xml">
            <list string="Xuất nhập kho Augges" create="false" edit="false">
                <header>
                    <button name="action_open_sync_wizard" type="object" string="Đồng bộ" class="btn-primary" display="always"/>
                </header>
                <field name="active" column_invisible="1"/>
                <field name="id_kho"/>
                <field name="co_so"/>
                <field name="id_dv"/>
                <field name="id_nx"/>
                <field name="loai_nx"/>
                <field name="loai_phieu"/>
                <field name="ngay_ct"/>
                <field name="sngay"/>
                <field name="insert_date"/>
                <field name="id_phieu"/>
                <field name="so_phieu"/>
                <field name="dien_giai"/>
                <field name="id_hang"/>
                <field name="ma_hang"/>
                <field name="ma_vach"/>
                <field name="ten_hang"/>
                <field name="so_luong"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_xuat_nhap_kho_augges_form" model="ir.ui.view">
        <field name="name">ttb.xuat.nhap.kho.augges.form</field>
        <field name="model">ttb.xuat.nhap.kho.augges</field>
        <field name="arch" type="xml">
            <form string="Xuất nhập kho Augges" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="id_kho"/>
                            <field name="co_so"/>
                            <field name="id_dv"/>
                            <field name="id_nx"/>
                            <field name="loai_nx"/>
                            <field name="loai_phieu"/>
                            <field name="ngay_ct"/>
                            <field name="sngay"/>
                            <field name="insert_date"/>
                            <field name="id_phieu"/>
                            <field name="so_phieu"/>
                        </group>
                        <group>
                            <field name="dien_giai"/>
                            <field name="id_hang"/>
                            <field name="ma_hang"/>
                            <field name="ma_vach"/>
                            <field name="ten_hang"/>
                            <field name="so_luong"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_xuat_nhap_kho_augges" model="ir.actions.act_window">
        <field name="name">Xuất nhập Kho Augges</field>
        <field name="res_model">ttb.xuat.nhap.kho.augges</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <!-- Menu: Tồn kho -> Báo cáo -> Xuất nhập Kho Augges -->
    <menuitem id="menu_xuat_nhap_kho_augges"
              name="Xuất nhập Kho Augges"
              parent="stock.menu_warehouse_report"
              action="action_xuat_nhap_kho_augges"
              sequence="15"/>
</odoo>
