<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_xuat_nhap_kho_augges_sync_wizard_form" model="ir.ui.view">
        <field name="name">ttb.xuat.nhap.kho.augges.sync.wizard.form</field>
        <field name="model">ttb.xuat.nhap.kho.augges.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Đồng bộ Xuất nhập kho Augges">
                <group>
                    <field name="date_start" widget="datetime"/>
                    <field name="date_end" widget="datetime"/>
                </group>
                <group string="SQL tùy chọn">
                    <field name="custom_sql" nolabel="1" placeholder="Để trống dùng SQL mặc định theo khoảng ngày trên. Có thể dán nguyên câu SQL nếu cần chạy tùy chỉnh (cột trùng với báo cáo)."/>
                </group>
                <footer>
                    <button name="action_sync" string="Đồng bộ" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
