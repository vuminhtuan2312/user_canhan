<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_vendor_master_list" model="ir.ui.view">
        <field name="name">vendor.master.list</field>
        <field name="model">vendor.master</field>
        <field name="arch" type="xml">
            <list string="NCC Master">
                <field name="vendor_code"/>
                <field name="street"/>
                <field name="supplier_id"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="return_condition"/>
                <field name="payment_term"/>
            </list>
        </field>
    </record>
    <record id="view_vendor_master_form" model="ir.ui.view">
        <field name="name">vendor.master.form</field>
        <field name="model">vendor.master</field>
        <field name="arch" type="xml">
            <form string="NCC Master">
                <sheet>
                    <group>
                        <group>
                            <field name="vendor_code"/>
                            <field name="supplier_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="discount_condition"/>
                            <field name="street"/>
                            <field name="return_condition"/>
                            <field name="payment_term"/>
                            <field name="discount_condition"/>
                            <field name="contract_file" widget="many2many_binary"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_vendor_master" model="ir.actions.act_window">
        <field name="name">NCC Master</field>
        <field name="res_model">vendor.master</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
