<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_popup_filtered_view_form" model="ir.ui.view">
        <field name="name">ttb.popup.filtered.form</field>
        <field name="model">ttb.popup.filtered</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Lọc" class="btn-primary" type="object" name="button_confirm" data-hotkey="enter"/>
                    <button string="Hủy" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="ttb_popup_filtered_action" model="ir.actions.act_window">
        <field name="name">Lọc thời gian</field>
        <field name="res_model">ttb.popup.filtered</field>
        <field name="view_mode">form</field>
    </record>

</odoo>
