<odoo>
    <record id="view_choose_result_wizard_form" model="ir.ui.view">
        <field name="name">choose.result.wizard.form</field>
        <field name="model">choose.result.wizard</field>
        <field name="arch" type="xml">
            <form string="Chọn kết quả">
                <group>
                    <field name="choice"/>
                </group>
                <footer>
                    <button string="Xác nhận"
                            type="object"
                            name="action_confirm"
                            class="btn-primary"/>
                    <button string="Hủy"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>