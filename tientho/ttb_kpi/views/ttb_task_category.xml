<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_task_category_view_tree" model="ir.ui.view">
        <field name="name">ttb.task.category.view.list</field>
        <field name="model">ttb.task.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
            </list>
        </field>
    </record>

     <record id="ttb_task_category_action" model="ir.actions.act_window">
        <field name="name">Danh mục nhiệm vụ</field>
        <field name="res_model">ttb.task.category</field>
        <field name="view_mode">list</field>
     </record>

</odoo>
