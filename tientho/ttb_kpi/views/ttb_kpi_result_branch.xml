<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
     <record id="ttb_kpi_result_branch_view_tree" model="ir.ui.view">
        <field name="name">ttb.kpi.result.branch.view.list</field>
        <field name="model">ttb.kpi.result.branch</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="name"/>
                <field name="branch_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="avg_vs_score" />
                <field name="avg_vm_score" />
            </list>
        </field>
    </record>
    <record id="ttb_kpi_result_branch_view_form" model="ir.ui.view">
        <field name="name">ttb.kpi.result.branch.view.form</field>
        <field name="model">ttb.kpi.result.branch</field>
        <field name="arch" type="xml">
            <form create="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="branch_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_from" string="Thời gian đánh giá" widget="daterange" options="{'end_date_field': 'date_to'}" readonly="1"/>
                            <field name="date_to" invisible="1" readonly="1"/>
                            <field name="score" invisible="1"/>
                            <field name="avg_vs_score" readonly="1"/>
                            <field name="avg_vm_score" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="ttb_task_report_kpi" string="Chi tiết đánh giá">
                            <field name="report_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="kpi_type_id"/>
                                    <field name="date"/>
                                    <field name="report_id" string="Phiếu nhiệm vụ"/>
                                    <field name="group" string="Nhóm đánh giá" />
                                    <field name="average_rate"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="ttb_kpi_result_branch_action" model="ir.actions.act_window">
        <field name="name">Kết quả KPI cơ sở</field>
        <field name="res_model">ttb.kpi.result.branch</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
