<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_kpi_type_group_view_list" model="ir.ui.view">
        <field name="name">ttb.kpi.type.group.view.list</field>
        <field name="model">ttb.kpi.type.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="menu_report_id"/>
                <field name="kpi_type_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="ttb_kpi_type_group_view_form" model="ir.ui.view">
        <field name="name">ttb.kpi.type.group.view.form</field>
        <field name="model">ttb.kpi.type.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="menu_report_id"/>
                        <field name="kpi_type_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ttb_kpi_type_group_action" model="ir.actions.act_window">
        <field name="name">Nhóm KPI</field>
        <field name="res_model">ttb.kpi.type.group</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
