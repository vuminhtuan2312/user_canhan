<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_kpi_result_kvc_view_list" model="ir.ui.view">
        <field name="name">ttb.kpi.result.kvc.view.list</field>
        <field name="model">ttb.kpi.result.kvc</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="name" />
                <field name="branch_id" />
                <field name="period" />
                <field name="avg_score" />
            </list>
        </field>
    </record>
    <record id="ttb_kpi_result_kvc_action" model="ir.actions.act_window">
        <field name="name">Kết quả KPI khu vui chơi</field>
        <field name="res_model">ttb.kpi.result.kvc</field>
        <field name="view_mode">list</field>
    </record>
</odoo>