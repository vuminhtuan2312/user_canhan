    <record id="ttb_task_report_line_view_kanban" model="ir.ui.view">
        <field name="name">ttb.task.report.line.view.kanban</field>
        <field name="model">ttb.task.report.line</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile o_kanban_small_column" create="0" delete="0" can_open="0" default_order="sequence" limit="2000">
                <field name="x_pass"/>
                <field name="fail"/>
                <field name="sequence"/>
                <field name="template_line_id"/>
                <field name="requirement"/>
                <field name="state" invisible="1"/>
                <field name="image_ids" widget="many2many_binary"/>
                <templates>
                    <t t-name="card">
                        <div class="row mb4">
                            <div  class="col-6">
                                <b>
                                    <field name="sequence"/>
                                    <span class="o_form_label">. </span>
                                    <field name="template_line_id"/>
                                </b>
                            </div>
                            <div name="button_x_pass" class="col-2">
                                <button invisible="x_pass == False" class="btn btn-primary" name="button_x_pass" type="object">Đạt</button>
                                <button invisible="x_pass == True" class="btn btn-outline-secondary" name="button_x_pass" type="object">Đạt</button>
                            </div>
                            <div name="button_fail" class="col-2">
                                <button invisible="fail == False"  class="btn btn-primary" name="button_fail" type="object">Không</button>
                                <button invisible="fail == True" class="btn btn-outline-secondary" name="button_fail" type="object">Không</button>
                            </div>
                        </div>
                        <div class="row mb4">
                            <div  class="col-6">
                                <i>
                                    <field name="requirement"/>
                                </i>
                            </div>
<!--                            <div name="action_open_image" class="col-4">-->
<!--                                <button invisible="state == 'done'" class="btn btn-primary" name="action_open_image" type="object">Chụp ảnh</button>-->
<!--                            </div>-->
                        </div>
                        <div class="row mb4">
                            <div class="col-10 oe_kanban_card">
                                <field name="image_ids" widget="many2many_binary"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="ttb_task_report_line_view_search" model="ir.ui.view">
        <field name="name">ttb.task.report.line.view.search</field>
        <field name="model">ttb.task.report.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_branch_id"/>
                <field name="area_id"/>
                <field name="categ_id"/>
                <field name="reviewer_id"/>
                <field name="user_id" filter_domain="['|', ('user_id', 'ilike', self), ('user_ids', 'ilike', self)]"/>
                <filter string="Đạt" name="x_pass_filter" domain="[('x_pass', '=', True)]"/>
                <filter string="Không đạt" name="fail_filter" domain="[('fail', '=', True)]"/>
                <filter string="Ngày đánh giá" name="filter_date" date="date"/>
                <group string="Group By">
                    <filter string="Loại KPI" name="groupby_kpi_type" context="{'group_by': 'kpi_type'}"/>
                    <filter string="Cơ sở" name="groupby_user_branch_id" context="{'group_by': 'user_branch_id'}"/>
                    <filter string="Khu vực" name="groupby_area_id" context="{'group_by': 'area_id'}"/>
                    <filter string="Quầy" name="groupby_categ_id" context="{'group_by': 'categ_id'}"/>
                    <filter string="Ngày đánh giá" name="groupby_date" context="{'group_by': 'date'}"/>
                    <filter string="Người đánh giá" name="groupby_reviewer_id" context="{'group_by': 'reviewer_id'}"/>
                    <filter string="Người được đánh giá" name="groupby_user_id" context="{'group_by': 'user_id'}"/>
                    <filter string="Tiêu chí đánh giá" name="groupby_template_line_id" context="{'group_by': 'template_line_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="ttb_task_report_kpi_view_list" model="ir.ui.view">
        <field name="name">ttb.task.report.kpi.view.list</field>
        <field name="model">ttb.task.report.kpi</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" editable="top">
                <header>
                    <button string="" title="Lọc theo ngày" icon="fa-calendar" type="object" name="button_filterd_date" class="btn" display="always"/>
                </header>
                <field name="report_id" string="Phiếu đánh giá" readonly="1" options="{'no_create': True,'no_open': True}"/>
                <field name="kpi_type" readonly="1" options="{'no_create': True,'no_open': True}"/>
                <field name="date" readonly="1"/>
                <field name="reviewer_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                <field name="user_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                <field name="user_branch_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                <field name="area_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                <field name="categ_id" optional="show" readonly="1" options="{'no_create': True,'no_open': True}"/>
                <field name="creation_month" options="{'no_create': True,'no_open': True}" />
                <field name="period" options="{'no_create': True,'no_open': True}" />
                <field name="average_rate" optional="show" widget="percentage" readonly="1"/>
                <field name="total_rate" optional="show" widget="percentage" readonly="1"/>
            </list>
        </field>
    </record>

