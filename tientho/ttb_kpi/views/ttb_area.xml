<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_kpi_area_view_tree" model="ir.ui.view">
        <field name="name">ttb.area.view.list</field>
        <field name="model">ttb.area</field>
        <field name="arch" type="xml">
            <list editable="top" default_order="id desc">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="ttb_kpi_area_action" model="ir.actions.act_window">
        <field name="name">Khu Vực</field>
        <field name="res_model">ttb.area</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
