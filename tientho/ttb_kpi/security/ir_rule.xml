<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<!--        Cài đặt nhiệm vụ ttb.task.template-->

    <record id="ttb_task_template_user_rule" model="ir.rule">
        <field name="name">Xem danh mục nhiệm vụ của vị trí của chính mình</field>
        <field name="model_id" ref="model_ttb_task_template"/>
        <field name="groups" eval="[(4, ref('ttb_kpi.group_ttb_kpi_warehouse_user')), (4, ref('ttb_kpi.group_ttb_kpi_warehouse_manager')), (4, ref('ttb_kpi.group_ttb_kpi_vhkd_director')), (4, ref('ttb_kpi.group_ttb_kpi_tnkh_manager')), (4, ref('ttb_kpi.group_ttb_kpi_brand_director'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">['|', ('job_ids', '=', False), ('job_ids', '=', user.employee_id.job_id.id)]</field>
    </record>

    <record id="ttb_task_template_sckh_rule" model="ir.rule">
        <field name="name">Nhân viên CSKH xem danh mục nhiệm vụ CSKH</field>
        <field name="model_id" ref="model_ttb_task_template"/>
        <field name="groups" eval="[(4, ref('ttb_kpi.group_ttb_kpi_nv_cskh'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('kpi_type_id.code', '=', 'CSKH')]</field>
    </record>

    <record id="ttb_task_template_warehouse_manager_rule" model="ir.rule">
        <field name="name">Các cấp quản lý có thể xem các cài đặt nhiệm vụ của nhân viên mình</field>
        <field name="model_id" ref="model_ttb_task_template"/>
        <field name="groups" eval="[(4, ref('ttb_kpi.group_ttb_kpi_warehouse_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('job_ids.employee_ids', 'child_of', user.employee_id.id)]</field>
    </record>

    <record id="ttb_task_template_asm_rule" model="ir.rule">
        <field name="name">Giám đốc vùng được full quyền xem</field>
        <field name="model_id" ref="model_ttb_task_template"/>
        <field name="groups" eval="[(4, ref('ttb_kpi.group_ttb_kpi_asm'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ttb_task_template_manager_rule" model="ir.rule">
        <field name="name">Cài đặt tất cả danh mục nhiệm vụ chỉ được tạo, thêm, sửa, xóa đối với danh mục mình tạo ra</field>
        <field name="model_id" ref="model_ttb_task_template"/>
        <field name="groups" eval="[(4, ref('ttb_kpi.group_ttb_kpi_vhkd_director')), (4, ref('ttb_kpi.group_ttb_kpi_tnkh_manager')), (4, ref('ttb_kpi.group_ttb_kpi_brand_director'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="domain_force">[('create_uid','=', user.id)]</field>
    </record>

    <record id="ttb_task_template_tnkh_manager_rule" model="ir.rule">
        <field name="name">Cài đặt tất cả danh mục nhiệm vụ: Trưởng nhóm trải nhiệm khách hàng có quyền tạo, thêm, sửa, xóa đối với loại CSKH</field>
        <field name="model_id" ref="model_ttb_task_template"/>
        <field name="groups" eval="[(4, ref('ttb_kpi.group_ttb_kpi_tnkh_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="domain_force">[('kpi_type_id.code', '=', 'CSKH')]</field>
    </record>

    <record id="ttb_task_template_system_rule" model="ir.rule">
        <field name="name">Quản trị thiết lập full quyền</field>
        <field name="model_id" ref="model_ttb_task_template"/>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

        <!--    Quyền bổ sung theo vị trí -->

