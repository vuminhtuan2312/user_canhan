<odoo noupdate="1">
    <record id="ir_cron_achieve" model="ir.cron">
        <field name="name">Tự động tính thực đạt</field>
        <field name="model_id" ref="model_ttb_kpi_target_line"/>
        <field name="state">code</field>
        <field name="code">model._cron_compute_achieve()</field>
        <field name="interval_number">2</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_kpi_result" model="ir.cron">
        <field name="name">Tự động sinh bản ghi Kết quả KPI</field>
        <field name="model_id" ref="model_ttb_kpi_result"/>
        <field name="state">code</field>
        <field name="code">model._cron_create_data()</field>
        <field name="nextcall" eval="(DateTime.now().replace(day=1, hour=18, minute=0) + relativedelta(months=1, days=-1)).strftime('%Y-%m-%d %H:%M:%S')" />
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_kpi_result_branch" model="ir.cron">
        <field name="name">Tạo kết quả KPI cơ sở tự động</field>
