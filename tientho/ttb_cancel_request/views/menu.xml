<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_cancel_root" name="Hủy hàng" sequence="10" web_icon="inventory_cancel_request,static/description/icon.png"/>

    <record id="action_cancel_request" model="ir.actions.act_window">
        <field name="name">Đề xuất hủy hàng</field>
        <field name="res_model">cancel.request</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo đề xuất hủy hàng mới</p>
        </field>
    </record>
    <menuitem id="menu_cancel_request" parent="menu_cancel_root" action="action_cancel_request" sequence="10"/>

    <record id="action_cancel_picking_pick" model="ir.actions.act_window">
        <field name="name">Nhặt hàng</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cancel_request_id', '!=', False), ('picking_type_code', '=', 'incoming')]</field>
        <field name="context">{'create': False, 'edit': True}</field>
    </record>
    <menuitem id="menu_cancel_picking_pick" parent="menu_cancel_root" action="action_cancel_picking_pick" sequence="20"/>

    <record id="action_cancel_picking_transfer" model="ir.actions.act_window">
        <field name="name">Điều chuyển VP</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cancel_request_id', '!=', False), ('picking_type_code', '=', 'internal')]</field>
        <field name="context">{'create': False, 'edit': True}</field>
    </record>
    <menuitem id="menu_cancel_picking_transfer" parent="menu_cancel_root" action="action_cancel_picking_transfer" sequence="30"/>

    <record id="action_cancel_picking_cancel" model="ir.actions.act_window">
        <field name="name">Hủy hàng</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cancel_request_id', '!=', False), ('picking_type_code', '=', 'outgoing')]</field>
        <field name="context">{'create': False, 'edit': True}</field>
    </record>
    <menuitem id="menu_cancel_picking_cancel" parent="menu_cancel_root" action="action_cancel_picking_cancel" sequence="40"/>

    <menuitem id="menu_cancel_config" parent="menu_cancel_root" name="Cấu hình" sequence="100"/>

    <record id="action_cancel_reason" model="ir.actions.act_window">
        <field name="name">Lý do hủy hàng</field>
        <field name="res_model">cancel.reason</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_cancel_reason" parent="menu_cancel_config" action="action_cancel_reason" sequence="10"/>
</odoo>