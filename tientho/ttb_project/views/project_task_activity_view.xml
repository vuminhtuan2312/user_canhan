<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Action để mở danh sách project.task.activity -->
    <record id="action_project_task_activity" model="ir.actions.act_window">
        <field name="name">Nhiệm vụ gần đây</field>
        <field name="res_model">project.task.activity</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Không có hoạt động nào gần đây.
            </p>
        </field>
    </record>

    <!-- Menuitem: Nhiệm vụ gần đây (con của Nhiệm vụ trong module Dự án) -->
    <menuitem
        id="menu_project_task_activity"
        name="Nhiệm vụ gần đây"
        parent="project.menu_project_management"
        action="action_project_task_activity"
        sequence="100"
    />

    <!-- List view cho model project.task.activity -->
    <record id="view_project_task_activity_list" model="ir.ui.view">
        <field name="name">project.task.activity.list</field>
        <field name="model">project.task.activity</field>
        <field name="arch" type="xml">
            <list string="Nhiệm vụ gần đây">
                <field name="activity_date"/>
                <field name="task_id"/>
                <field name="activity_type"/>
                <field name="activity_id"/>
                <field name="subtype_id"/>
                <field name="activity_user_id"/>
                <field name="body" widget="html"/>
            </list>
        </field>
    </record>

    <!-- Form view cho model project.task.activity -->
    <record id="view_project_task_activity_form" model="ir.ui.view">
        <field name="name">project.task.activity.form</field>
        <field name="model">project.task.activity</field>
        <field name="arch" type="xml">
            <form string="Chi tiết hoạt động">
                <group>
                    <field name="activity_date"/>
                    <field name="task_id"/>
                    <field name="activity_type"/>
                    <field name="activity_id"/>
                    <field name="subtype_id"/>
                    <field name="activity_user_id"/>
                    <field name="body" widget="html"/>
                </group>
            </form>
        </field>
    </record>

</odoo>
