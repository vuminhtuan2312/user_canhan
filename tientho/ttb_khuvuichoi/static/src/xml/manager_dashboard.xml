<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ttb_khuvuichoi.ManagerDashboard" owl="1">
        <div class="o_ttb_manager_dashboard o_ttb_dashboard_scroll p-3">
            <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="o_ttb_dashboard_title_with_switch d-flex align-items-center gap-2">
                        <div class="o_ttb_dashboard_title_texts position-relative">
                            <span class="o_ttb_dashboard_title_text h2 m-0" t-att-class="state.viewMode === 'overview' ? 'o_ttb_dashboard_title_text--active' : ''">Tổng quan công việc</span>
                            <span class="o_ttb_dashboard_title_text h2 m-0 position-absolute top-0 start-0" t-att-class="state.viewMode === 'report' ? 'o_ttb_dashboard_title_text--active' : ''">Tổng quan báo cáo</span>
                        </div>
                        <i class="fa fa-retweet o_ttb_dashboard_switch_icon cursor-pointer"
                            role="button"
                            t-att-title="state.viewMode === 'report' ? 'Chuyển sang Tổng quan công việc' : 'Chuyển sang Tổng quan báo cáo'"
                            t-att-class="state.viewMode === 'report' ? 'o_ttb_dashboard_switch_icon--active' : ''"
                            t-on-click.stop.prevent="() => this.toggleViewMode()"/>
                    </div>
                </div>
                <div class="o_ttb_clock_vn text-end">
                    <div class="o_ttb_clock_date text-muted small" t-esc="state.currentTimeVNDate"/>
                    <div class="o_ttb_clock_time fw-semibold" t-esc="state.currentTimeVNTime"/>
                </div>
            </div>

            <!-- Bảng chào: luôn hiển thị ở cả Tổng quan công việc và Tổng quan báo cáo -->
            <div class="o_ttb_manager_greeting mb-4">
                <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-4">
                    <div class="d-flex align-items-center gap-4 flex-shrink-0">
                        <div class="o_ttb_employee_avatar-wrap">
                            <t t-if="getAvatarUrl()">
                                <img t-att-src="getAvatarUrl()" class="o_ttb_employee_avatar" alt="Avatar" />
                            </t>
                            <t t-else="">
                                <div class="o_ttb_employee_avatar o_ttb_employee_avatar_placeholder">
                                    <i class="fa fa-user"/>
                                </div>
                            </t>
                        </div>
                        <div>
                            <h3 class="mb-0 fw-bold">
                                Chào, <span t-esc="state.meta.employee_name || 'Quản lý'"/>
                            </h3>
                            <div class="o_ttb_employee_role_branch text-muted small mt-1" t-if="state.meta.role_label || state.meta.branch_names">
                                <t t-if="state.meta.role_label">
                                    <span t-esc="state.meta.role_label"/>
                                </t>
                                <t t-if="state.meta.role_label and state.meta.branch_names">
                                    <span class="mx-1">•</span>
                                </t>
                                <t t-if="state.meta.branch_names">
                                    <span t-esc="state.meta.branch_names"/>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-2 flex-grow-1 flex-md-grow-0 justify-content-md-end align-items-stretch align-items-md-end">
                        <div class="text-muted small">
                            <span>Bộ lọc: <strong t-esc="state.rangeLabel"/></span>
                            <span class="mx-1">•</span>
                            <span>Thời gian cập nhật: <t t-esc="formatLastRefreshedAt()"/></span>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <div class="btn-group" role="group" aria-label="Time range">
                                <button class="btn btn-sm" t-att-class="state.rangeKey === 'today' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('today')">Hôm nay</button>
                                <button class="btn btn-sm" t-att-class="state.rangeKey === '7_days' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('7_days')">7 Ngày</button>
                                <button class="btn btn-sm" t-att-class="state.rangeKey === '15_days' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('15_days')">15 Ngày</button>
                                <button class="btn btn-sm" t-att-class="state.rangeKey === '30_days' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('30_days')">30 Ngày</button>
                                <button class="btn btn-sm" t-att-class="state.rangeKey === 'all' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('all')">Toàn bộ</button>
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" t-on-click="toggleAutoRefresh">
                                <t t-esc="state.autoRefreshEnabled ? 'Auto refresh: Bật' : 'Auto refresh: Tắt'"/>
                            </button>
                            <span class="text-muted small" t-if="state.autoRefreshEnabled">
                                Refresh sau: <strong t-esc="state.nextRefreshInSec"/>s
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Nội dung Tổng quan công việc: ẩn với hiệu ứng mờ khi chuyển sang Báo cáo -->
            <div class="o_ttb_dashboard_overview" t-att-class="state.viewMode === 'report' ? 'o_ttb_dashboard_overview--hidden' : ''">
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_assigned" role="button" tabindex="0" t-on-click="() => openTasksByKpi('assigned')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc của cơ sở</div>
                            <div class="display-6" t-esc="state.counts.assigned"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_done" role="button" tabindex="0" t-on-click="() => openTasksByKpi('done')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc đã hoàn thành</div>
                            <div class="display-6 text-success" t-esc="state.counts.done"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_not_done" role="button" tabindex="0" t-on-click="() => openTasksByKpi('not_done')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc cần thực hiện</div>
                            <div class="display-6 text-warning" t-esc="state.counts.not_done"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_late" role="button" tabindex="0" t-on-click="() => openTasksByKpi('late')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc trễ hạn</div>
                            <div class="display-6 text-danger" t-esc="state.counts.late"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header o_ttb_section_header d-flex align-items-center justify-content-center justify-content-md-between flex-wrap gap-2">
                    <strong class="w-100 w-md-auto text-center">Phiếu phân công ca</strong>
                    <span class="text-muted small order-md-last" t-if="state.loading">Đang tải…</span>
                </div>
                <div class="card-body">
                    <t t-if="state.loading">
                        <p class="text-muted mb-0">Đang tải dữ liệu…</p>
                    </t>
                    <t t-elif="!state.shiftAssignments.length">
                        <p class="text-muted mb-0">Chưa có phiếu phân công ca nào.</p>
                    </t>
                    <t t-else="">
                        <div class="row g-2 g-md-3">
                            <t t-foreach="state.shiftAssignments" t-as="sa" t-key="'sa_' + sa.id">
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <div class="card h-100 border-start border-3 o_ttb_task_card_clickable"
                                        role="button" tabindex="0"
                                        t-att-class="'border-3 ' + (sa.state === 'done' ? 'border-success' : (sa.state === 'assigning' ? 'border-warning' : (sa.state === 'draft' ? 'border-info' : (sa.state === 'cancel' ? 'border-secondary' : 'border-primary'))))"
                                        t-on-click="() => this.openShiftAssignment(sa.id)"
                                        t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.openShiftAssignment(sa.id)">
                                        <div class="card-body py-2 px-3">
                                            <div class="d-flex flex-wrap gap-1 mb-1">
                                                <span class="badge" t-att-class="assignmentStateBadgeClass(sa.state)">
                                                    <t t-esc="sa.state_label"/>
                                                </span>
                                            </div>
                                            <h6 class="card-title mb-1 text-break" style="font-size: 0.95rem;">
                                                <t t-esc="sa.name"/>
                                            </h6>
                                            <div class="text-muted small mb-0" t-esc="sa.shift_name || '-'"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header o_ttb_section_header d-flex align-items-center justify-content-center justify-content-md-between flex-wrap gap-2">
                    <strong class="w-100 w-md-auto text-center">Công việc của nhân viên</strong>
                    <span class="text-muted small order-md-last" t-if="state.loading">Đang tải…</span>
                </div>
                <div class="card-body">
                    <t t-if="state.loading">
                        <p class="text-muted mb-0">Đang tải dữ liệu…</p>
                    </t>
                    <t t-elif="!state.employeeTasks.length">
                        <p class="text-muted mb-0">Chưa có công việc nào.</p>
                    </t>
                    <t t-else="">
                        <t t-foreach="this.getAreaGroupsEmployee()" t-as="areaGroup" t-key="areaGroup.areaKey">
                            <div class="mb-3 o_ttb_area_group">
                                <div class="o_ttb_area_header align-middle py-2 px-3 rounded" role="button" tabindex="0" t-on-click="() => this.toggleAreaExpand('emp', areaGroup.areaKey)" t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleAreaExpand('emp', areaGroup.areaKey)">
                                    <span class="me-2 o_ttb_area_chevron" t-att-class="this.isAreaExpanded('emp', areaGroup.areaKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                    <strong t-esc="areaGroup.areaName"/>
                                    <span class="text-muted ms-1">[ <t t-esc="formatPercent(areaGroup.percent)"/>% hoàn thành ]</span>
                                </div>
                                <t t-if="this.isAreaExpanded('emp', areaGroup.areaKey)">
                                    <div class="o_ttb_area_group_body">
                                    <t t-foreach="this.getEmployeeGroupsForAreaEmployee(areaGroup)" t-as="empGroup" t-key="empGroup.employeeKey">
                                        <div class="m-3 o_ttb_employee_group">
                                            <div class="o_ttb_employee_header align-middle py-2 px-3 rounded" role="button" tabindex="0" t-on-click="() => this.toggleEmployeeExpand('emp', areaGroup.areaKey, empGroup.employeeKey)" t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleEmployeeExpand('emp', areaGroup.areaKey, empGroup.employeeKey)">
                                                <span class="me-2 o_ttb_area_chevron" t-att-class="this.isEmployeeExpanded('emp', areaGroup.areaKey, empGroup.employeeKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                                <strong>Người thực hiện: <t t-esc="empGroup.employeeName"/></strong>
                                                <span class="text-muted ms-1">[ <t t-esc="formatPercent(empGroup.percent)"/>% hoàn thành ]</span>
                                            </div>
                                            <t t-if="this.isEmployeeExpanded('emp', areaGroup.areaKey, empGroup.employeeKey)">
                                                <div class="row g-2 g-md-3 mt-2 mb-2">
                                                    <t t-foreach="empGroup.tasks" t-as="task" t-key="task.id">
                                                        <div class="col-12 col-sm-6 col-lg-4">
                                                            <div class="card h-100 o_ttb_task_card border-start border-3 o_ttb_task_card_clickable" role="button" tabindex="0" t-att-class="'border-3 ' + (this.getTaskCardBorderClass(task) || 'border-secondary')" t-on-click="() => this.openTask(task.id)" t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.openTask(task.id)">
                                                                <div class="card-body py-2 px-3">
                                                                    <div class="d-flex flex-wrap gap-1 mb-1">
                                                                        <span t-if="task.is_late" class="badge text-bg-danger">Trễ hạn</span>
                                                                        <span class="badge" t-att-class="statusBadgeClass(task.status)">
                                                                            <t t-esc="task.status_label"/>
                                                                        </span>
                                                                    </div>
                                                                    <h6 class="card-title mb-1 text-break" style="font-size: 0.95rem;">
                                                                        <t t-esc="task.name"/>
                                                                    </h6>
                                                                    <div class="text-muted small mb-1" t-esc="task.employee_name || 'Chưa giao'"/>
                                                                    <div class="text-muted small mb-1">
                                                                        <i class="fa fa-clock-o me-1"/>
                                                                        <t t-esc="formatExecutionTime(task)"/>
                                                                    </div>
                                                                    <p t-if="task.note" class="card-text small text-secondary mb-0 text-truncate" style="max-height: 2.5em;" t-esc="task.note"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </t>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </t>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header o_ttb_section_header d-flex align-items-center justify-content-center justify-content-md-between flex-wrap gap-2">
                    <strong class="w-100 w-md-auto text-center">Phiếu hậu kiểm</strong>
                    <span class="text-muted small order-md-last" t-if="state.loading">Đang tải…</span>
                </div>
                <div class="card-body">
                    <t t-if="state.loading">
                        <p class="text-muted mb-0">Đang tải dữ liệu…</p>
                    </t>
                    <t t-elif="!this.getPostAuditsSorted().length">
                        <p class="text-muted mb-0">Chưa có phiếu hậu kiểm nào.</p>
                    </t>
                    <t t-else="">
                        <div class="row g-2 g-md-3">
                            <t t-foreach="this.getPostAuditsSorted()" t-as="pa" t-key="'pa_' + pa.id">
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <div class="card h-100 border-start border-3 o_ttb_task_card_clickable"
                                        role="button" tabindex="0"
                                        t-att-class="'border-3 ' + (pa.state === 'done' ? 'border-success' : (pa.state === 'pending' ? 'border-warning' : 'border-secondary'))"
                                        t-on-click="() => this.openPostAudit(pa.id)"
                                        t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.openPostAudit(pa.id)">
                                        <div class="card-body py-2 px-3">
                                            <div class="d-flex flex-wrap gap-1 mb-1">
                                                <span class="badge" t-att-class="pa.state === 'done' ? 'text-bg-success' : (pa.state === 'pending' ? 'text-bg-warning' : 'text-bg-secondary')">
                                                    <t t-esc="pa.state_label || pa.state"/>
                                                </span>
                                            </div>
                                            <h6 class="card-title mb-1 text-break" style="font-size: 0.95rem;">
                                                <t t-esc="pa.name"/>
                                            </h6>
                                            <div class="text-muted small mb-1" t-esc="pa.shift_name || '-'"/>
                                            <div class="text-muted small mb-1">
                                                <span class="me-2"><i class="fa fa-calendar-o me-1"/> <t t-esc="formatDate(pa.assignment_date)"/></span>
                                            </div>
                                            <div class="text-muted small mb-0">
                                                <i class="fa fa-clock-o me-1"/> <t t-esc="formatDateTime(pa.inspection_time)"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>

            <div class="card">
                <div class="card-header o_ttb_section_header d-flex align-items-center justify-content-center justify-content-md-between flex-wrap gap-2">
                    <strong class="w-100 w-md-auto text-center">Công việc không đạt</strong>
                    <span class="text-muted small order-md-last" t-if="state.loading">Đang tải…</span>
                </div>
                <div class="card-body">
                    <t t-if="state.loading">
                        <p class="text-muted mb-0">Đang tải dữ liệu…</p>
                    </t>
                    <t t-elif="!state.failedAuditLines.length">
                        <p class="text-muted mb-0">Không có công việc nào không đạt.</p>
                    </t>
                    <t t-else="">
                        <t t-foreach="this.getAreaGroupsFailedLines()" t-as="areaGroup" t-key="'fail_area_' + areaGroup.areaKey">
                            <div class="mb-3 o_ttb_area_group">
                                <div class="o_ttb_area_header align-middle py-2 px-3 rounded" role="button" tabindex="0"
                                    t-on-click="() => this.toggleAreaExpandFailed(areaGroup.areaKey)"
                                    t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleAreaExpandFailed(areaGroup.areaKey)">
                                    <span class="me-2 o_ttb_area_chevron" t-att-class="this.isAreaExpandedFailed(areaGroup.areaKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                    <strong t-esc="areaGroup.areaName"/>
                                </div>
                                <t t-if="this.isAreaExpandedFailed(areaGroup.areaKey)">
                                    <div class="o_ttb_area_group_body">
                                        <t t-foreach="this.getEmployeeGroupsForAreaFailedLines(areaGroup)" t-as="empGroup" t-key="'fail_emp_' + areaGroup.areaKey + '_' + empGroup.employeeKey">
                                            <div class="m-3 o_ttb_employee_group">
                                                <div class="o_ttb_employee_header align-middle py-2 px-3 rounded" role="button" tabindex="0"
                                                    t-on-click="() => this.toggleEmployeeExpandFailed(areaGroup.areaKey, empGroup.employeeKey)"
                                                    t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleEmployeeExpandFailed(areaGroup.areaKey, empGroup.employeeKey)">
                                                    <span class="me-2 o_ttb_area_chevron" t-att-class="this.isEmployeeExpandedFailed(areaGroup.areaKey, empGroup.employeeKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                                    <strong>Nhân viên phụ trách: <t t-esc="empGroup.employeeName"/></strong>
                                                </div>
                                                <t t-if="this.isEmployeeExpandedFailed(areaGroup.areaKey, empGroup.employeeKey)">
                                                    <div class="row g-2 g-md-3 mt-2 mb-2">
                                                        <t t-foreach="empGroup.lines" t-as="line" t-key="'fail_' + line.id">
                                                            <div class="col-12 col-sm-6 col-lg-4">
                                                                <div class="card h-100 border-start border-3 border-danger">
                                                                    <div class="card-body py-2 px-3">
                                                                        <span class="badge text-bg-danger mb-1">Không đạt</span>
                                                                        <h6 class="card-title mb-1 text-break" style="font-size: 0.95rem;" t-esc="line.template_line_name"/>
                                                                        <div class="text-muted small mb-1" t-esc="line.area_name"/>
                                                                        <div class="text-muted small mb-1" t-esc="line.employee_names"/>
                                                                        <div class="text-muted small mb-1">
                                                                            <i class="fa fa-clock-o me-1"/><t t-esc="formatDateTime(line.actual_date_end)"/>
                                                                        </div>
                                                                        <p t-if="line.note" class="card-text small text-secondary mb-1 text-truncate" style="max-height: 2.5em;" t-esc="line.note"/>
                                                                        <t t-if="line.rework_task_id">
                                                                            <a href="#" class="small" t-on-click.prevent="() => this.openReworkTask(line.rework_task_id)">
                                                                                <i class="fa fa-external-link me-1"/> <t t-esc="line.rework_task_name"/>
                                                                            </a>
                                                                        </t>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </t>
                                                    </div>
                                                </t>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </t>
                </div>
            </div>
            </div>
            <!-- Kết thúc o_ttb_dashboard_overview -->

            <div class="o_ttb_dashboard_report" t-att-class="state.viewMode === 'report' ? 'o_ttb_dashboard_report--visible' : ''">
                <t t-if="state.viewMode === 'report'">
                    <!-- Biểu đồ cột: Điểm hậu kiểm (xanh dương) + Tỉ lệ hoàn thành (cam) theo khu vực -->
                    <div class="card mb-4 o_ttb_report_chart_card">
                        <div class="card-header o_ttb_section_header d-flex align-items-center justify-content-center justify-content-md-between flex-wrap gap-2">
                            <strong class="w-100 w-md-auto text-center">Biểu đồ hiệu suất theo khu vực</strong>
                        </div>
                        <div class="card-body o_ttb_report_chart_wrapper">
                            <canvas t-ref="reportChartCanvas" class="o_ttb_report_chart_canvas"/>
                        </div>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-header o_ttb_section_header d-flex align-items-center justify-content-center justify-content-md-between flex-wrap gap-2">
                                    <strong class="w-100 w-md-auto text-center">Hiệu suất hậu kiểm</strong>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover table-striped mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th scope="col">Khu vực</th>
                                                    <th scope="col" class="text-end">Tổng CV</th>
                                                    <th scope="col" class="text-end">Đạt</th>
                                                    <th scope="col" class="text-end">Không đạt</th>
                                                    <th scope="col" class="text-end">Tỷ lệ đạt</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-if="!state.reportPostAuditPerformance.length">
                                                    <tr>
                                                        <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu</td>
                                                    </tr>
                                                </t>
                                                <t t-else="" t-foreach="state.reportPostAuditPerformance" t-as="row" t-key="row.area_key">
                                                    <tr>
                                                        <td t-esc="row.area_name"/>
                                                        <td class="text-end" t-esc="row.total"/>
                                                        <td class="text-end text-success" t-esc="row.passed"/>
                                                        <td class="text-end text-danger" t-esc="row.failed"/>
                                                        <td class="text-end fw-semibold" t-esc="row.percent_display"/>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-header o_ttb_section_header d-flex align-items-center justify-content-center justify-content-md-between flex-wrap gap-2">
                                    <strong class="w-100 w-md-auto text-center">Hiệu suất hoàn thành</strong>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover table-striped mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th scope="col">Khu vực</th>
                                                    <th scope="col" class="text-end">Tổng CV</th>
                                                    <th scope="col" class="text-end">Hoàn thành</th>
                                                    <th scope="col" class="text-end">Chưa xong</th>
                                                    <th scope="col" class="text-end">Tỷ lệ hoàn thành</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-if="!state.reportCompletionPerformance.length">
                                                    <tr>
                                                        <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu</td>
                                                    </tr>
                                                </t>
                                                <t t-else="" t-foreach="state.reportCompletionPerformance" t-as="row" t-key="row.area_key">
                                                    <tr>
                                                        <td t-esc="row.area_name"/>
                                                        <td class="text-end" t-esc="row.total"/>
                                                        <td class="text-end text-success" t-esc="row.done"/>
                                                        <td class="text-end text-warning" t-esc="row.not_done"/>
                                                        <td class="text-end fw-semibold" t-esc="row.percent_display"/>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>

