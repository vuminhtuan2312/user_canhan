<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ttb_khuvuichoi.ManagerDashboard" owl="1">
        <div class="o_ttb_manager_dashboard o_ttb_dashboard_scroll p-3">
            <div class="d-flex align-items-start align-items-md-center justify-content-between mb-3 flex-column flex-md-row gap-2">
                <div>
                    <h2 class="m-0">Tổng quan</h2>
                    <div class="text-muted small">
                        Dành cho quản lý
                        <span class="mx-1">•</span>
                        <span>Thời gian: <strong t-esc="state.rangeLabel"/></span>
                        <span class="mx-1">•</span>
                        <span>Lần cập nhật: <t t-esc="formatLastRefreshedAt()"/></span>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="btn-group" role="group" aria-label="Time range">
                        <button class="btn btn-sm" t-att-class="state.rangeKey === 'before' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('before')">Trước</button>
                        <button class="btn btn-sm" t-att-class="state.rangeKey === 'today' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('today')">Hôm nay</button>
                        <button class="btn btn-sm" t-att-class="state.rangeKey === 'tomorrow' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('tomorrow')">Ngày mai</button>
                        <button class="btn btn-sm" t-att-class="state.rangeKey === 'all' ? 'btn-primary' : 'btn-outline-primary'" t-on-click="() => setRange('all')">Toàn bộ</button>
                    </div>

                    <button class="btn btn-outline-secondary btn-sm" t-on-click="toggleAutoRefresh">
                        <t t-esc="state.autoRefreshEnabled ? 'Auto refresh: Bật' : 'Auto refresh: Tắt'"/>
                    </button>
                    <span class="text-muted small" t-if="state.autoRefreshEnabled">
                        Refresh sau: <strong t-esc="state.nextRefreshInSec"/>s
                    </span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_assigned" role="button" tabindex="0" t-on-click="() => openTasksByKpi('assigned')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc của cơ sở</div>
                            <div class="display-6" t-esc="state.counts.assigned"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_done" role="button" tabindex="0" t-on-click="() => openTasksByKpi('done')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc đã hoàn thành</div>
                            <div class="display-6 text-success" t-esc="state.counts.done"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_not_done" role="button" tabindex="0" t-on-click="() => openTasksByKpi('not_done')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc cần thực hiện</div>
                            <div class="display-6 text-warning" t-esc="state.counts.not_done"/>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="card h-100 o_ttb_kpi_card o_ttb_kpi_late" role="button" tabindex="0" t-on-click="() => openTasksByKpi('late')">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số công việc trễ hạn</div>
                            <div class="display-6 text-danger" t-esc="state.counts.late"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <strong>Công việc của nhân viên</strong>
                    <span class="text-muted small" t-if="state.loading">Đang tải…</span>
                </div>
                <div class="table-responsive o_ttb_table_scroll">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="min-width: 280px;">Tên công việc</th>
                                <th style="min-width: 160px;">Thời gian phân công</th>
                                <th style="min-width: 200px;">Người thực hiện</th>
                                <th style="min-width: 260px;">Thời gian thực hiện</th>
                                <th style="min-width: 140px;">Trạng thái</th>
                                <th style="min-width: 320px;">Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.loading">
                                <tr>
                                    <td colspan="6" class="text-muted">Đang tải dữ liệu…</td>
                                </tr>
                            </t>
                            <t t-elif="!state.employeeTasks.length">
                                <tr>
                                    <td colspan="6" class="text-muted">Chưa có công việc nào.</td>
                                </tr>
                            </t>
                            <t t-else="">
                                <t t-foreach="this.getAreaGroupsEmployee()" t-as="areaGroup" t-key="areaGroup.areaKey">
                                    <tr class="o_ttb_area_header align-middle" role="button" tabindex="0" t-on-click="() => this.toggleAreaExpand('emp', areaGroup.areaKey)" t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleAreaExpand('emp', areaGroup.areaKey)">
                                        <td colspan="6" class="py-2">
                                            <span class="me-2 o_ttb_area_chevron" t-att-class="this.isAreaExpanded('emp', areaGroup.areaKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                            <strong t-esc="areaGroup.areaName"/>
                                            <span class="text-muted ms-1">[ <t t-esc="areaGroup.percent"/>% hoàn thành ]</span>
                                        </td>
                                    </tr>
                                    <t t-if="this.isAreaExpanded('emp', areaGroup.areaKey)">
                                        <t t-foreach="this.getEmployeeGroupsForAreaEmployee(areaGroup)" t-as="empGroup" t-key="empGroup.employeeKey">
                                            <tr class="o_ttb_employee_header align-middle" role="button" tabindex="0" t-on-click="() => this.toggleEmployeeExpand('emp', areaGroup.areaKey, empGroup.employeeKey)" t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleEmployeeExpand('emp', areaGroup.areaKey, empGroup.employeeKey)">
                                                <td colspan="6" class="py-2 ps-4">
                                                    <span class="me-2 o_ttb_area_chevron" t-att-class="this.isEmployeeExpanded('emp', areaGroup.areaKey, empGroup.employeeKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                                    <strong>Người thực hiện: <t t-esc="empGroup.employeeName"/></strong>
                                                    <span class="text-muted ms-1">[ <t t-esc="empGroup.percent"/>% hoàn thành ]</span>
                                                </td>
                                            </tr>
                                            <t t-if="this.isEmployeeExpanded('emp', areaGroup.areaKey, empGroup.employeeKey)">
                                                <t t-foreach="empGroup.tasks" t-as="task" t-key="task.id">
                                                    <tr t-att-class="this.taskRowClass(task)">
                                                        <td>
                                                            <a href="#" t-on-click.prevent="() => openTask(task.id)">
                                                                <t t-esc="task.name"/>
                                                            </a>
                                                        </td>
                                                        <td t-esc="formatDate(task.assignment_date)"/>
                                                        <td t-esc="task.employee_name || '-'"/>
                                                        <td t-esc="formatExecutionTime(task)"/>
                                                        <td>
                                                            <span class="badge" t-att-class="statusBadgeClass(task.status)">
                                                                <t t-esc="task.status_label"/>
                                                            </span>
                                                        </td>
                                                        <td class="text-truncate" style="max-width: 520px;" t-esc="task.note"/>
                                                    </tr>
                                                </t>
                                            </t>
                                        </t>
                                    </t>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <strong>Phiếu hậu kiểm</strong>
                    <span class="text-muted small" t-if="state.loading">Đang tải…</span>
                </div>
                <div class="table-responsive o_ttb_table_scroll">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="min-width: 160px;">Khu vực</th>
                                <th style="min-width: 200px;">Phiếu hậu kiểm</th>
                                <th style="min-width: 160px;">Ca làm việc</th>
                                <th style="min-width: 140px;">Thời gian phân công</th>
                                <th style="min-width: 180px;">Thời gian hậu kiểm</th>
                                <th style="min-width: 140px;">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.loading">
                                <tr>
                                    <td colspan="6" class="text-muted">Đang tải dữ liệu…</td>
                                </tr>
                            </t>
                            <t t-elif="!state.postAuditsByArea.length">
                                <tr>
                                    <td colspan="6" class="text-muted">Chưa có phiếu hậu kiểm nào.</td>
                                </tr>
                            </t>
                            <t t-else="">
                                <t t-foreach="state.postAuditsByArea" t-as="areaGroup" t-key="'pa_area_' + (areaGroup.area_id || 0)">
                                    <t t-foreach="areaGroup.post_audits" t-as="pa" t-key="'pa_' + pa.id">
                                        <tr>
                                            <td t-esc="areaGroup.area_name"/>
                                            <td>
                                                <a href="#" t-on-click.prevent="() => this.openPostAudit(pa.id)">
                                                    <t t-esc="pa.name"/>
                                                </a>
                                            </td>
                                            <td t-esc="pa.shift_name"/>
                                            <td t-esc="formatDate(pa.assignment_date)"/>
                                            <td t-esc="formatDateTime(pa.inspection_time)"/>
                                            <td>
                                                <span class="badge" t-att-class="pa.state === 'done' ? 'text-bg-success' : (pa.state === 'pending' ? 'text-bg-warning' : 'text-bg-secondary')">
                                                    <t t-esc="pa.state_label || pa.state"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <strong>Công việc không đạt</strong>
                    <span class="text-muted small" t-if="state.loading">Đang tải…</span>
                </div>
                <div class="table-responsive o_ttb_table_scroll">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="min-width: 160px;">Khu vực</th>
                                <th style="min-width: 220px;">Tên công việc</th>
                                <th style="min-width: 200px;">Nhân viên phụ trách</th>
                                <th style="min-width: 180px;">Thời gian thực hiện</th>
                                <th style="min-width: 120px;">Trạng thái</th>
                                <th style="min-width: 280px;">Ghi chú</th>
                                <th style="min-width: 220px;">Công việc khắc phục</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.loading">
                                <tr>
                                    <td colspan="7" class="text-muted">Đang tải dữ liệu…</td>
                                </tr>
                            </t>
                            <t t-elif="!state.failedAuditLines.length">
                                <tr>
                                    <td colspan="7" class="text-muted">Không có công việc nào không đạt.</td>
                                </tr>
                            </t>
                            <t t-else="">
                                <t t-foreach="this.getAreaGroupsFailedLines()" t-as="areaGroup" t-key="'fail_area_' + areaGroup.areaKey">
                                    <tr class="o_ttb_area_header align-middle" role="button" tabindex="0" t-on-click="() => this.toggleAreaExpandFailed(areaGroup.areaKey)" t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleAreaExpandFailed(areaGroup.areaKey)">
                                        <td colspan="7" class="py-2">
                                            <span class="me-2 o_ttb_area_chevron" t-att-class="this.isAreaExpandedFailed(areaGroup.areaKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                            <strong t-esc="areaGroup.areaName"/>
                                        </td>
                                    </tr>
                                    <t t-if="this.isAreaExpandedFailed(areaGroup.areaKey)">
                                        <t t-foreach="this.getEmployeeGroupsForAreaFailedLines(areaGroup)" t-as="empGroup" t-key="'fail_emp_' + areaGroup.areaKey + '_' + empGroup.employeeKey">
                                            <tr class="o_ttb_employee_header align-middle" role="button" tabindex="0" t-on-click="() => this.toggleEmployeeExpandFailed(areaGroup.areaKey, empGroup.employeeKey)" t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.toggleEmployeeExpandFailed(areaGroup.areaKey, empGroup.employeeKey)">
                                                <td colspan="7" class="py-2 ps-4">
                                                    <span class="me-2 o_ttb_area_chevron" t-att-class="this.isEmployeeExpandedFailed(areaGroup.areaKey, empGroup.employeeKey) ? 'fa fa-chevron-down' : 'fa fa-chevron-right'"/>
                                                    <strong>Nhân viên phụ trách: <t t-esc="empGroup.employeeName"/></strong>
                                                </td>
                                            </tr>
                                            <t t-if="this.isEmployeeExpandedFailed(areaGroup.areaKey, empGroup.employeeKey)">
                                                <t t-foreach="empGroup.lines" t-as="line" t-key="'fail_' + line.id">
                                                    <tr class="table-danger">
                                                        <td t-esc="line.area_name"/>
                                                        <td t-esc="line.template_line_name"/>
                                                        <td t-esc="line.employee_names"/>
                                                        <td t-esc="formatDateTime(line.actual_date_end)"/>
                                                        <td>
                                                            <span class="badge text-bg-danger">Không đạt</span>
                                                        </td>
                                                        <td class="text-truncate" style="max-width: 280px;" t-esc="line.note"/>
                                                        <td>
                                                            <t t-if="line.rework_task_id">
                                                                <a href="#" t-on-click.prevent="() => this.openReworkTask(line.rework_task_id)">
                                                                    <t t-esc="line.rework_task_name"/>
                                                                </a>
                                                            </t>
                                                            <t t-else="">-</t>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </t>
                                    </t>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </t>
</templates>

