<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view: Phiếu hậu kiểm -->
    <record id="view_ttb_post_audit_list" model="ir.ui.view">
        <field name="name">ttb.post.audit.list</field>
        <field name="model">ttb.post.audit</field>
        <field name="arch" type="xml">
            <list decoration-warning="state == 'pending'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'" default_order="state asc, inspection_time desc, id desc">
                <field name="name"/>
                <field name="assignment_id"/>
                <field name="shift_id"/>
                <field name="branch_id"/>
                <field name="area_id"/>
                <field name="inspector_ids" widget="many2many_tags_avatar"/>
                <field name="inspection_time"/>
                <field name="state" widget="badge" decoration-warning="state == 'pending'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <!-- Form view: Phiếu hậu kiểm -->
    <record id="view_ttb_post_audit_form" model="ir.ui.view">
        <field name="name">ttb.post.audit.form</field>
        <field name="model">ttb.post.audit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_done" string="Xác nhận" type="object" class="btn-success" invisible="state != 'pending'" confirm="Bạn có chắc chắn muốn xác nhận phiếu hậu kiểm này?"/>
                    <button name="action_cancel" string="Huỷ" type="object" class="btn-danger" invisible="state != 'pending'" confirm="Bạn có chắc chắn muốn huỷ phiếu hậu kiểm này?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Thông tin phiếu phân công">
                            <field name="assignment_id" readonly="1"/>
                            <field name="shift_id" readonly="1"/>
                            <field name="branch_id"/>
                            <field name="area_id" readonly="1"/>
                        </group>
                        <group string="Thông tin hậu kiểm">
                            <field name="inspector_ids" widget="many2many_tags_avatar"/>
                            <field name="inspection_time" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết hậu kiểm" name="lines">
                            <field name="line_ids">
                                <list editable="bottom" decoration-success="is_pass" decoration-danger="is_fail or rework_task_id" create="false" delete="false">
                                    <field name="template_line_id" readonly="1"/>
                                    <field name="employee_ids" widget="many2many_tags_avatar" readonly="1"/>
                                    <field name="rework_task_id" readonly="1" optional="show" decoration-danger="rework_task_id"/>
                                    <field name="note" optional="show" readonly="state != 'pending'"/>
                                    <field name="is_pass" readonly="is_fail == True or state != 'pending'"/>
                                    <field name="is_fail" readonly="is_pass == True or state != 'pending'"/>
                                    <field name="proof_image" options="{'size': [300, 300]}" widget="capture_image" readonly="state != 'pending'" invisible="not is_fail"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view: Phiếu hậu kiểm -->
    <record id="view_ttb_post_audit_search" model="ir.ui.view">
        <field name="name">ttb.post.audit.search</field>
        <field name="model">ttb.post.audit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="assignment_id"/>
                <field name="area_id"/>
                <field name="shift_id"/>
                <field name="area_id"/>
                <field name="branch_id"/>
                <field name="inspector_ids"/>
                <filter string="Chờ kiểm tra" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Đạt" name="filter_pass" domain="[('state', '=', 'pass')]"/>
                <filter string="Không đạt" name="filter_fail" domain="[('state', '=', 'fail')]"/>
                <group expand="0" string="Group By">
                    <filter string="Khu vực" name="group_area" context="{'group_by': 'area_id'}"/>
                    <filter string="Ca làm việc" name="group_shift" context="{'group_by': 'shift_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Phiếu hậu kiểm -->
    <record id="action_ttb_post_audit" model="ir.actions.act_window">
        <field name="name">Phiếu hậu kiểm</field>
        <field name="res_model">ttb.post.audit</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_pending': 1}</field>
    </record>

    <!-- Menu: Phiếu hậu kiểm (trong Quản lý) -->
    <menuitem id="menu_ttb_post_audit" name="Phiếu hậu kiểm" parent="ttb_menu_management" action="action_ttb_post_audit" sequence="25"/>
</odoo>
