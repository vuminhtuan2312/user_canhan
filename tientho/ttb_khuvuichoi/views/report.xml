<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Báo cáo: Pivot + Graph + 3 Actions + Menu cha + 3 Menu con -->

    <record id="view_ttb_operational_task_pivot" model="ir.ui.view">
        <field name="name">ttb.operational.task.pivot</field>
        <field name="model">ttb.operational.task</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="employee_id" type="row"/>
                <field name="area_id" type="row"/>
                <field name="planned_date_start" interval="month" type="col"/>
                <field name="planned_date_start" interval="day" type="col"/>
                <field name="completion_rate" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_ttb_operational_task_pivot_audit" model="ir.ui.view">
        <field name="name">ttb.operational.task.pivot.audit</field>
        <field name="model">ttb.operational.task</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="employee_id" type="row"/>
                <field name="area_id" type="row"/>
                <field name="planned_date_start" interval="month" type="col"/>
                <field name="planned_date_start" interval="day" type="col"/>
                <field name="audit_score_percent" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_ttb_operational_task_graph" model="ir.ui.view">
        <field name="name">ttb.operational.task.graph</field>
        <field name="model">ttb.operational.task</field>
        <field name="arch" type="xml">
            <graph type="bar" stacked="True">
                <field name="planned_date_start" interval="day"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <record id="action_report_operations" model="ir.actions.act_window">
        <field name="name">Tổng quan Vận hành</field>
        <field name="res_model">ttb.operational.task</field>
        <field name="view_mode">graph,pivot</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>

    <record id="action_report_performance" model="ir.actions.act_window">
        <field name="name">Hoàn thành</field>
        <field name="res_model">ttb.operational.task</field>
        <field name="view_mode">pivot,graph</field>
        <field name="context">{'pivot_measures': ['completion_rate', '__count']}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_ttb_operational_task_pivot')}), 
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_ttb_operational_task_graph')})]"/>
    </record>

    <record id="action_report_audit" model="ir.actions.act_window">
        <field name="name">Hậu kiểm</field>
        <field name="res_model">ttb.operational.task</field>
        <field name="view_mode">pivot,graph</field>
        <field name="domain">[('is_audit_required', '=', True)]</field>
        <field name="context">{'pivot_measures': ['audit_score_percent', '__count']}</field>
        <field name="view_ids" eval="[(5, 0, 0), 
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_ttb_operational_task_pivot_audit')}), 
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_ttb_operational_task_graph')})]"/>
    </record>

    <record id="action_report_quality" model="ir.actions.act_window">
        <field name="name">Chất lượng &amp; Hậu kiểm</field>
        <field name="res_model">ttb.post.audit</field>
        <field name="view_mode">graph,pivot</field>
        <field name="domain">[]</field>
    </record>

    <menuitem id="ttb_menu_report_operations" name="Tổng quan Vận hành" parent="ttb_menu_reporting" action="action_report_operations" sequence="10"/>

    <menuitem id="ttb_menu_report_performance" name="Hiệu suất Nhân sự" parent="ttb_menu_reporting" sequence="20"/>
    <menuitem id="ttb_menu_report_audit" name="Hậu kiểm" parent="ttb_menu_report_performance" action="action_report_audit" sequence="23"/>
    <menuitem id="ttb_menu_report_completion" name="Hoàn thành" parent="ttb_menu_report_performance" action="action_report_performance" sequence="25"/>

    <menuitem id="ttb_menu_report_quality" name="Chất lượng &amp; Hậu kiểm" parent="ttb_menu_reporting" action="action_report_quality" sequence="30"/>
</odoo>
