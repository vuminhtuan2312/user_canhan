<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard: Báo cáo tạm hoãn (generic - dùng ở Lý do tạm hoãn / nơi khác) -->
    <record id="view_ttb_task_delay_wizard_form" model="ir.ui.view">
        <field name="name">ttb.task.delay.wizard.form</field>
        <field name="model">ttb.task.delay.wizard</field>
        <field name="arch" type="xml">
            <form string="Báo cáo Tạm hoãn">
                <group>
                    <field name="reason_id" options="{'no_create': True}"/>
                    <field name="note" placeholder="Mô tả chi tiết sự cố..."/>
                </group>
                <footer>
                    <button name="action_confirm_delay" string="Xác nhận" type="object" class="btn-primary"/>
                    <button string="Hủy bỏ" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>