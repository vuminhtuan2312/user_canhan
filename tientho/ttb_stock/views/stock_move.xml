<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_move_kandan" model="ir.ui.view">
        <field name="name">stock.move.kanban</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_kandan"/>
        <field name="arch" type="xml">
            <field name="product_qty" position="after">
                <field name="ttb_product_code"/>
                <field name="ttb_barcode_k"/>
                <field name="ttb_barcode_vendor"/>
                <field name="ttb_default_code"/>
            </field>
            <field name="product_id" position="after">
                <span>
                    Mã sản phẩm <field name="ttb_product_string"/>
                </span>
                <div>
                    <span>Giá <field name="ttb_price_unit"/></span><br/>
                </div>
            </field>
        </field>
    </record>
</odoo>