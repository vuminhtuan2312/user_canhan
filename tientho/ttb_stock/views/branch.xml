<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="branch_list" model="ir.ui.view">
        <field name="name">Cơ sở</field>
        <field name="model">ttb.branch</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="vat_warehouse_id"/>
                <field name="branch_director" />
                <field name="snd_location_id"/>
            </list>
        </field>
    </record>
    
    <record id="branch_search" model="ir.ui.view">
        <field name="name">Cơ sở</field>
        <field name="model">ttb.branch</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" filter_domain="['|', ('code', 'ilike', self), ('name', 'ilike', self)]"/>
            </search>
        </field>
    </record>

    <record id="branch_action" model="ir.actions.act_window">
        <field name="name">Cơ sở</field>
        <field name="res_model">ttb.branch</field>
        <field name="view_mode">list</field>
    </record>
</odoo>