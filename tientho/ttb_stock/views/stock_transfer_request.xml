<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="stock_transfer_request_view_list" model="ir.ui.view">
        <field name="name">stock.transfer.request.view.list</field>
        <field name="model">stock.transfer.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="picking_ids"/>
                <field name="request_user_id"/>
                <field name="transfer_type"/>
                <field name="request_date"/>
                <field name="approve_date"/>
                <field name="source_warehouse_id"/>
                <field name="dest_warehouse_id"/>
            </list>
        </field>
    </record>
    <record id="stock_transfer_request_view_form" model="ir.ui.view">
        <field name="name">stock.transfer.request.view.form</field>
        <field name="model">stock.transfer.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_approve" string="Gửi duyệt" class="btn-primary" type="object" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Duyệt" invisible="not approve_ok or state != 'pending'" type="object" class="btn-primary"/>
                    <button name="action_reset" string="Chỉnh sửa" invisible="state != 'pending'" type="object" class="btn_primary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="picking_ids" readonly="1"/>
                            <field name="request_user_id" readonly="1"/>
                            <field name="transfer_type" readonly="state != 'draft'"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="1"/>
                            <field name="approve_date" readonly="1"/>
                            <field name="source_warehouse_id"/>
                            <field name="dest_warehouse_id" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết điều chuyển hàng">
                            <button name="action_import_product" string="Nhập sản phẩm" type="object" invisible="state != 'draft'"  class="btn btn-primary"/>
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="default_code"/>
                                    <field name="product_id"/>
                                    <field name="uom_id"/>
                                    <field name="quantity"/>
                                </list>
                            </field>
                        </page>
                        <page string="Thông tin phê duyệt" name="approval_info">
                            <group>
                                <group>
                                    <field name="current_approve_user_ids" readonly="1" widget="many2many_tags"/>
                                    <field name="next_approve_user_ids" readonly="1" widget="many2many_tags"/>
                                    <field name="notif_user_ids" readonly="1" widget="many2many_tags"/>
                                </group>
                                <group groups="base.group_no_one">
                                    <field name="process_id" readonly="1" groups="base.group_no_one"/>
                                    <field name="date_sent" readonly="1" groups="base.group_no_one"/>
                                    <field name="date_approved" readonly="1" groups="base.group_no_one"/>
                                </group>
                            </group>
                            <field name="rule_line_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="stock_transfer_request_action" model="ir.actions.act_window">
        <field name="name">Phiếu đề nghị chuyển hàng</field>
        <field name="res_model">stock.transfer.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
