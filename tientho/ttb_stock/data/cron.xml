<odoo noupdate="0">

	<record id="ir_sync_outgoing_stock_picking" model="ir.cron">
		<field name="name">Đồng bộ phiếu xuất kho</field>
		<field name="model_id" ref="ttb_stock.model_stock_picking"/>
		<field name="state">code</field>
		<field name="code">model.sync_outgoing_stock_picking()</field>
		<field name="interval_number">2</field>
		<field name="interval_type">minutes</field>
		<field name="active">False</field>
	</record>

	<record id="ir_sync_internal_stock_picking" model="ir.cron">
		<field name="name">Đồng bộ phiếu nhập nội bộ</field>
		<field name="model_id" ref="ttb_stock.model_stock_picking"/>
		<field name="state">code</field>
		<field name="code">model.sync_internal_stock_picking()</field>
		<field name="interval_number">2</field>
		<field name="interval_type">minutes</field>
		<field name="active">False</field>
	</record>

	<record id="ir_sync_return_stock_picking" model="ir.cron">
		<field name="name">Đồng bộ phiếu trả hàng</field>
		<field name="model_id" ref="ttb_stock.model_stock_picking"/>
		<field name="state">code</field>
		<field name="code">model.sync_return_stock_picking()</field>
		<field name="interval_number">2</field>
		<field name="interval_type">minutes</field>
		<field name="active">False</field>
	</record>

	<record id="ir_sync_incoming_stock_picking" model="ir.cron">
		<field name="name">Đồng bộ phiếu nhập</field>
		<field name="model_id" ref="ttb_stock.model_stock_picking"/>
		<field name="state">code</field>
		<field name="code">model.sync_incoming_stock_picking()</field>
		<field name="interval_number">2</field>
		<field name="interval_type">minutes</field>
		<field name="active">False</field>
	</record>
</odoo>
