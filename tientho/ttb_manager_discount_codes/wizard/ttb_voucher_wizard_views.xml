<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_voucher_wizard_form" model="ir.ui.view">
        <field name="name">ttb.voucher.wizard.form</field>
        <field name="model">ttb.voucher.wizard</field>
        <field name="arch" type="xml">
            <form string="Mã ưu đãi">
                <div class="oe_title">
                    <h1>
                        <field name="voucher_code"/>
                    </h1>
                </div>
                <group>
                    <field name="message" readonly="1"/>
                </group>
                <footer>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
