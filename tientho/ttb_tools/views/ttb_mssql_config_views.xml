<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="mssql_config_view_form" model="ir.ui.view">
        <field name="name">mssql.config.view.form</field>
        <field name="model">ttb.mssql.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" string="Test connection" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="server"/>
                            <field name="username"/>
                            <field name="password_input"/>
                        </group>
                        <group>
                            <field name="driver"/>
                            <field name="database"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="mssql_config_view_list" model="ir.ui.view">
        <field name="name">mssql.config.view.list</field>
        <field name="model">ttb.mssql.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="server"/>
                <field name="username"/>
                <field name="database"/>
                <field name="priority" widget="handle"/>
            </list>
        </field>
    </record>
    <record id="mssql_config_action" model="ir.actions.act_window">
        <field name="name">Cấu hình mã hóa MSSQL</field>
        <field name="res_model">ttb.mssql.config</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_mssql_config"
          name="Cấu hình mã hóa MSSQL"
          action="ttb_tools.mssql_config_action"
          parent="base.menu_custom"
          sequence="99"/>
</odoo>
