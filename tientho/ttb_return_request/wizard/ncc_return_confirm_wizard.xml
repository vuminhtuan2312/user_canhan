<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ncc_return_confirm_wizard_form_view" model="ir.ui.view">
        <field name="name">ncc.return.confirm.wizard.form</field>
        <field name="model">ncc.return.confirm.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="return_request_id" readonly="1"/>
                    <field name="message" readonly="1"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Xác nhận" type="object" class="btn-primary"/>
                    <button name="action_cancel" string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
