<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_warehouse_inherit_return_request" model="ir.ui.view">
        <field name="name">stock.warehouse.form.inherit.return.request</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='xdock_type_id']" position="after">
                <field name="return_type_id"/>
            </xpath>
        </field>
    </record>

        <record id="ttb_branch_view_tree_inherit_return_request" model="ir.ui.view">
        <field name="name">ttb.branch.view_tree.inherit.return.request</field>
        <field name="model">ttb.branch</field>
        <field name="inherit_id" ref="ttb_stock.branch_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="ttb_branch_region"/>
            </xpath>
        </field>
    </record>
</odoo>