<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="einvoice_serial_form" model="ir.ui.view">
        <field name="name">Ký hiệu hóa đơn điện tử</field>
        <field name="model">ttb.einvoice.serial</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. VNPT-EInvoice"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="description"/>
                            <field name="service_id"/>
                            <field name="branch_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="pattern"/>
                            <field name="type"/>
                            <field name="active" widget="boolean_toggle" options="{'autosave': False}" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="einvoice_serial_list" model="ir.ui.view">
        <field name="name">Ký hiệu hóa đơn điện tử</field>
        <field name="model">ttb.einvoice.serial</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
                <field name="service_id"/>
                <field name="branch_ids" widget="many2many_tags"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="einvoice_serial_search" model="ir.ui.view">
        <field name="name">Ký hiệu hóa đơn điện tử</field>
        <field name="model">ttb.einvoice.serial</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="service_id"/>
                <field name="type"/>
                <filter name="inactive" string="Đã lưu trữ" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="einvoice_serial_action" model="ir.actions.act_window">
        <field name="name">Ký hiệu hóa đơn điện tử</field>
        <field name="res_model">ttb.einvoice.serial</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>