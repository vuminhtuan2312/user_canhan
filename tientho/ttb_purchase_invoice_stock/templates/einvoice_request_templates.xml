<!--                                        toggleVatField();-->

<!--                                        // Add event listener for changes-->
<!--                                        isStateAgencyCheckbox.addEventListener('change', toggleVatField);-->
<!--                                    });-->
<!--                                </script>-->
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>