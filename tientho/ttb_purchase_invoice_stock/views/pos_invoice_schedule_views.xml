<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="pos_invoice_schedule_view_form" model="ir.ui.view">
        <field name="name">ttb.pos.invoice.schedule.form</field>
        <field name="model">ttb.pos.invoice.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="time_from" widget="float_time"/>
                            <field name="time_to" widget="float_time"/>
                            <field name="branch_ids" widget="many2many_tags"/>
                            <field name="enabled"/>
                            <field name="note"/>
                        </group>
                        
                        <group>
                            <field name="time_schedule" widget="float_time"/>
                            <field name="to_step"/>
                            <field name="kvc"/>
                            <field name="get_bank_transfer"/>
                            <field name="get_cash_transfer"/>
                            <field name="khop_tien_mat"/>
                            <field name="cron_id"/>
                        </group>
                    </group>
                    
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="pos_invoice_schedule_view_list" model="ir.ui.view">
        <field name="name">ttb.pos.invoice.schedule.list</field>
        <field name="model">ttb.pos.invoice.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="time_from" optional="hide"/>
                <field name="time_to" optional="hide"/>
                <field name="time_schedule"/>
                <field name="kvc" optional="show"/>
                <field name="get_bank_transfer" optional="hide"/>
                <field name="get_cash_transfer" optional="show"/>
                <field name="branch_ids" widget="many2many_tags" optional="show"/>
                <field name="enabled"/>
            </list>
        </field>
    </record>

    <record id="ttb_pos_invoice_schedule_action" model="ir.actions.act_window">
        <field name="name">Lịch xuất hoá đơn điện tử tự động</field>
        <field name="res_model">ttb.pos.invoice.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="ttb_pos_invoice_config_menu"
        name="Xuất hoá đơn"
        parent="purchase.menu_purchase_config"
    />

    <menuitem
        id="ttb_pos_invoice_schedule_menu"
        name="Lịch xuất hoá đơn điện tử tự động"
        parent="ttb_pos_invoice_config_menu"
        action="ttb_pos_invoice_schedule_action"
    />

</odoo>