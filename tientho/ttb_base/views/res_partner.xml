<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ttb_view_partner_property_form" model="ir.ui.view">
        <field name="name">ttb.res.partner.purchase.property.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <group name='purchase' position="inside">
                <field name="product_category"/>
                <field name="discount_product_category"/>
            </group>
            <xpath expr="//group[@name='misc']/field[@name='ref']" position="attributes">
                <attribute name="required">context.get('default_supplier_rank', False)</attribute>
            </xpath>
            <xpath expr="//field[@name='vat']" position="before">
                <field name="code" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='vat']" position="after">
                <field name="ttb_no_invoice"/>
                <field name="ttb_show_report"/>
                 <field name="accountant_id" domain="[('job_id', '=', 121)]"/>
            </xpath>
        </field>
    </record>
</odoo>
