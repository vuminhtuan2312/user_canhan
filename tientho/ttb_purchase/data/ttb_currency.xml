<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="chinese_money" model="res.currency">
            <field name="name">Tệ</field>
            <field name="symbol">¥</field>
            <field name="rounding">0.01</field>
            <field name="currency_unit_label">Yuan</field>
            <field name="currency_subunit_label">Jiao</field>
            <field name="decimal_places">2</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>