<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_ttb_purchase_request" model="ir.sequence">
        <field name="name">Purchase Request</field>
        <field name="code">purchase.request</field>
        <field name="prefix">PR</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_purchase_batch" model="ir.sequence">
        <field name="name">Purchase Batch</field>
        <field name="code">purchase.batch</field>
        <field name="prefix">BPR</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_product_allocation" model="ir.sequence">
        <field name="name">Product Allocation</field>
        <field name="code">product.allocation</field>
        <field name="prefix">PA</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_purchase_price" model="ir.sequence">
        <field name="name">Purchase Price</field>
        <field name="code">purchase.price</field>
        <field name="prefix">PP</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_purchase_approval" model="ir.sequence">
        <field name="name">Purchase Approval</field>
        <field name="code">purchase.approval</field>
        <field name="prefix">PD</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_supplier_product_code" model="ir.sequence">
        <field name="name">Supplier Product Code</field>
        <field name="code">purchase.request.line.item</field>
        <field name="prefix">NK</field>
        <field name="padding">7</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_advance_request" model="ir.sequence">
        <field name="name">Advance Request</field>
        <field name="code">advance.request</field>
        <field name="prefix">TU</field>
        <field name="padding">6</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_complaint_ticket" model="ir.sequence">
        <field name="name">Complaint Ticket</field>
        <field name="code">complaint.ticket</field>
        <field name="prefix">KN</field>
        <field name="padding">6</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>