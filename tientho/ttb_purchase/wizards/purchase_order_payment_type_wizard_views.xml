<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_payment_type_wizard_view_form" model="ir.ui.view">
        <field name="name">purchase.order.payment.type.wizard.form</field>
        <field name="model">purchase.order.payment.type.wizard</field>
        <field name="arch" type="xml">
            <form string="Vui lòng lựa chọn hình thức thanh toán">
                <group>
                    <field name="purchase_order_ids" widget="many2many_tags" readonly="1"/>
                    <field name="payment_type" widget="radio"/>
                </group>
                <footer>
                    <button name="action_confirm_payment_type" string="Xác nhận" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_purchase_order_payment_type_wizard" model="ir.actions.act_window">
        <field name="name">Đề nghị thanh toán</field>
        <field name="res_model">purchase.order.payment.type.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

