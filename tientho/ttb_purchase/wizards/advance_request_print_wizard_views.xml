<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="advance_request_print_wizard_view_form" model="ir.ui.view">
        <field name="name">advance.request.print.wizard.form</field>
        <field name="model">advance.request.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Chọn loại in">
                <group>
                    <field name="advance_request_id" invisible="1"/>
                    <field name="print_type" widget="radio"/>
                </group>
                <footer>
                    <button name="action_print" string="In" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_advance_request_print_wizard" model="ir.actions.act_window">
        <field name="name">In phiếu</field>
        <field name="res_model">advance.request.print.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

