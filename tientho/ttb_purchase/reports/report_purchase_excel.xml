<odoo>
      <record id="view_purchase_order_form_inherit_excel" model="ir.ui.view">
            <field name="name">purchase.order.form.excel</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_rfq_send']" position="before">
                    <button name="action_print_excel"
                            type="object"
                            string="In Excel"
                            class="btn btn-primary"
                            invisible="ttb_type != 'sale'"/>
                </xpath>
            </field>
      </record>
</odoo>
