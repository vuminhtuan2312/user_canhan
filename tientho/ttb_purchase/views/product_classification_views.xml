<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="product_classification_view_form" model="ir.ui.view">
        <field name="name">product.classification.view.form</field>
        <field name="model">product.classification</field>
        <field name="arch" type="xml">
            <form string="Phân loại sản phẩm">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="from_cumulative_percent"/>
                        <field name="to_cumulative_percent"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_classification_view_list" model="ir.ui.view">
        <field name="name">product.classification.view.list</field>
        <field name="model">product.classification</field>
        <field name="arch" type="xml">
            <list string="Phân loại sản phẩm">
                <field name="name"/>
                <field name="from_cumulative_percent"/>
                <field name="to_cumulative_percent"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="product_classification_action" model="ir.actions.act_window">
        <field name="name">Phân loại sản phẩm</field>
        <field name="res_model">product.classification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="product_classification_menu"
              name="Phân loại sản phẩm"
              parent="purchase.menu_purchase_config"
              action="product_classification_action"
              sequence="20"/>
</odoo>
