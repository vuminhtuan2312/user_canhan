<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form_purchase" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.purchase</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <setting id="po_order_approval" position="attributes">
                <attribute name="invisible">1</attribute>
            </setting>
            <setting id="automatic_lock_confirmed_orders" position="attributes">
                <attribute name="invisible">1</attribute>
            </setting>
            <setting id="automatic_lock_confirmed_orders" position="after">
                <setting id="ttb_lock_confirmed_orders" string="Tự động khóa đơn hàng" company_dependent="1">
                    <div class="content-group">
                        <div class="row mt16">
                            <label for="po_lock_from_date_approve" class="col-lg-3 o_light_label"/>
                            <field name="po_lock_from_date_approve"/>
                        </div>
                        <div class="row">
                            <label for="po_lock_from_date_receipt" class="col-lg-3 o_light_label"/>
                            <field name="po_lock_from_date_receipt"/>
                        </div>
                    </div>
                </setting>
            </setting>
        </field>
    </record>
</odoo>