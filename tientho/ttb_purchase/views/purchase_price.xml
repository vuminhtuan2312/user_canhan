<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="purchase_price_form" model="ir.ui.view">
        <field name="name">Đề nghị duyệt giá</field>
        <field name="model">ttb.purchase.price</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="sent_ok" invisible="1"/>
                    <field name="approve_ok" invisible="1"/>
                    <button name="action_sent" string="Gửi duyệt" invisible="not sent_ok or state != 'new'" type="object" class="btn-primary"/>
                    <button name="action_approve" string="Duyệt" invisible="not approve_ok or state != 'sent'" type="object" class="btn-primary"/>
                    <button name="action_reject" string="Từ chối" invisible="not approve_ok or state != 'sent'" type="object"/>
                    <button name="action_cancel" string="Hủy" invisible="state != 'new'" type="object"/>
                    <button name="action_update_pol_price_unit" string="Cập nhật giá PO" type="object" invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,sent,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state != 'new'"/>
                            <field name="user_id" readonly="state != 'new'"/>
                            <field name="company_id" groups="base.group_multi_company" invisible="1"/>
                        </group>
                        <group>
                            <field name="partner_id" readonly="state != 'new'"/>
                            <field name="date_applied" readonly="state != 'new'" options="{'min_date': 'today'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Danh sách sản phẩm" name="detail">
                            <button name="action_import_product" string="Nhập sản phẩm" type="object" invisble="state != 'new'" class="btn btn-primary"/>
                            <field name="line_ids" readonly="state != 'new'">
                                <list editable="bottom">
                                    <field name="default_code"/>
                                    <field name="barcode"/>
                                    <field name="product_id"/>
                                    <field name="packaging_id"/>
                                    <field name="old_price"/>
                                    <field name="old_discount"/>
                                    <field name="price"/>
                                    <field name="discount"/>
                                    <field name="new_tax" widget="many2many_tags"/>
                                    <field name="currency_id" groups="base.group_multi_currency"/>
                                    <field name="change_rate" widget="percentage"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="default_code"/>
                                            <field name="barcode"/>
                                            <field name="product_id"/>
                                            <field name="packaging_id"/>
                                        </group>
                                        <group>
                                            <field name="old_price"/>
                                            <field name="price"/>
                                            <field name="currency_id" groups="base.group_multi_currency"/>
                                            <field name="change_rate" widget="percentage"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Thông tin phê duyệt" name="approval_info">
                            <group>
                                <group>
                                    <field name="current_approve_user_ids" readonly="1" widget="many2many_tags"/>
                                    <field name="next_approve_user_ids" readonly="1" widget="many2many_tags"/>
                                    <field name="notif_user_ids" readonly="1" widget="many2many_tags"/>
                                </group>
                                <group groups="base.group_no_one">
                                    <field name="process_id" readonly="1" groups="base.group_no_one"/>
                                    <field name="date_sent" readonly="1" groups="base.group_no_one"/>
                                    <field name="date_approved" readonly="1" groups="base.group_no_one"/>
                                </group>
                            </group>
                            <field name="rule_line_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="purchase_price_list" model="ir.ui.view">
        <field name="name">Đề nghị duyệt giá</field>
        <field name="model">ttb.purchase.price</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="date_applied"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="purchase_price_search" model="ir.ui.view">
        <field name="name">Đề nghị duyệt giá</field>
        <field name="model">ttb.purchase.price</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="product_id"/>
                <filter string="Yêu cầu của tôi" name="my_request" domain="[('user_id', '=', uid)]"/>
                <filter string="Yêu cầu cần duyệt" name="my_approve" domain="[('state','=','sent'),('current_approve_user_ids', '=', uid)]"/>
                <separator/>
                <filter string="Đang duyệt" name="state_sent" domain="[('state','=','sent')]"/>
                <filter string="Đã duyệt" name="state_approved" domain="[('state','=','approved')]"/>

                <group expand="1" string="Group By">
                    <filter string="Người đề nghị" name="groupby_user_id" context="{'group_by':'user_id'}"/>
                    <filter string="Nhà cung cấp" name="groupby_partner_id" context="{'group_by':'partner_id'}"/>
                    <filter string="Ngày đề nghị" name="groupby_date" context="{'group_by': 'date:month'}"/>
                    <filter string="Ngày áp dụng" name="groupby_date_applied" context="{'group_by':'date_applied:month'}"/>
                    <filter string="Trạng thái" name="groupby_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="purchase_price_action" model="ir.actions.act_window">
        <field name="name">Đề nghị duyệt giá</field>
        <field name="res_model">ttb.purchase.price</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>