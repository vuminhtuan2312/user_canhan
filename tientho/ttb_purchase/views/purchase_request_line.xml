<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="purchase_request_line_list" model="ir.ui.view">
        <field name="name">Chi tiết yêu cầu mua hàng</field>
        <field name="model">ttb.purchase.request.line</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" edit="0">
                <header>
                    <button name="action_add_to_purchase_approval" type="object" string="Thêm vào tờ trình"/>
                </header>
                <field name="default_code"/>
                <field name="product_id"/>
                <field name="description"/>
                <field name="demand_qty"/>
                <field name="uom_id"/>
            </list>
        </field>
    </record>

    <record id="purchase_request_line_action" model="ir.actions.act_window">
        <field name="name">Chọn sản phẩm</field>
        <field name="res_model">ttb.purchase.request.line</field>
        <field name="view_id" ref="purchase_request_line_list"/>
        <field name="view_mode">list</field>
        <field name="target">new</field>
    </record>
</odoo>