<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="delivery_order_form" model="ir.ui.view">
        <field name="name">delivery.order.form</field>
        <field name="model">delivery.order</field>
        <field name="arch" type="xml">
            <form string="Delivery Order">
                <header>
                    <button name="action_confirm" string="Xác nhận" type="object" class="oe_highlight" invisible="state!='draft'"/>
                    <button name="action_cancel" string="Huỷ" type="object" invisible="state=='confirmed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="shipment_date"/>
                    </group>
                    <notebook>
                        <page string="Chi tiết phiếu">
                            <field name="delivery_order_ids">
                                <list editable="bottom">
                                    <field name="stock_picking_id"
                                           domain="[('ttb_stage', '=', '3'), ('state', '=', 'done')]"/>
                                    <field name="purchase_order_id"/>
                                    <field name="cbm_total"/>
                                    <field name="number_of_cases_total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú">
                            <field name="notes" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="delivery_order_list" model="ir.ui.view">
        <field name="name">delivery.order.list</field>
        <field name="model">delivery.order</field>
        <field name="arch" type="xml">
            <list string="Lệnh chuyển hàng">
                <field name="name"/>
                <field name="shipment_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_delivery_orders" model="ir.actions.act_window">
        <field name="name">Lệnh chuyển hàng</field>
        <field name="res_model">delivery.order</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="delivery_order_list"/>
    </record>
</odoo>