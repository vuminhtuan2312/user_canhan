<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_partner_property_form" model="ir.ui.view">
        <field name="name">res.partner.purchase.property.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="purchase.view_partner_property_form"/>
        <field name="arch" type="xml">
            <div name="receipt_reminder" position="after">
                <field name="ttb_consign"/>
            </div>
            <field name="property_purchase_currency_id" position="after">
                <field name="ttb_stock_limit" widget="percentage"/>
            </field>
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page name="Augges">
                    <field name="augges_id"/>
                </page>
            </xpath>
        </field>
    </record>
    <record id="inherit_res_partner_search" model="ir.ui.view">
        <field name="name">res.partner.search.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='name']" position="after">
                <field name="augges_id"/>
            </xpath>
        </field>
    </record>
</odoo>