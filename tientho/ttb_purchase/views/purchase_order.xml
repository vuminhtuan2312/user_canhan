    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="payment_term_note" invisible="ttb_type != 'not_sale'"/>
                <field name="additional_note" invisible="ttb_type != 'not_sale'"/>
                <field name="profit_margin" invisible="ttb_type != 'imported_goods'"/>
                <field name="cbm_total" invisible="ttb_type != 'imported_goods'" readonly="request_type == True"/>
                <field name="number_of_cases_total" invisible="ttb_type != 'imported_goods'" readonly="is_gift_category == False"/>
                <field name="exchange_rate" invisible="ttb_type != 'imported_goods'"/>
            </xpath>
            <xpath expr="//field[@name='notes']" position="after">
                <field name="china_stock_location" invisible="ttb_type != 'imported_goods'"/>
                <field name="vietnam_stock_location" invisible="ttb_type != 'imported_goods'"/>
                <field name="shipping_warehouse_id" invisible="ttb_type != 'imported_goods'"/>
                <field name="purchase_order_status" invisible="ttb_type != 'imported_goods'" readonly="1"/>
                <field name="attachment" invisible="ttb_type != 'imported_goods'"/>
            </xpath>
        </field>
    </record>

    <record id="action_print_estimated_costs" model="ir.actions.report">
