<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_complaint_ticket_form" model="ir.ui.view">
        <field name="name">complaint.ticket.form</field>
        <field name="model">complaint.ticket</field>
        <field name="arch" type="xml">
            <form string="Complaint Ticket">
                <header>
                    <button name="button_sent_complaint" string="Gửi duyệt" type="object" class="btn-primary"
                            invisible="state!='draft'"/>
                    <button name="button_confirm_complaint" string="Duyệt" type="object" class="btn-secondary"
                            invisible="state!='to_approve'"/>
                    <button name="button_complete_complaint" string="Hoàn thành" type="object" class="btn-primary"
                            invisible="state!='approved'"/>
                    <button name="button_cancel_complaint" string="Hủy" type="object" class="btn-primary"
                            invisible="state in ('approved', 'resolved')"/>
                    <button name="button_create_po" string="Tạo Po bù" type="object" class="btn-primary"
                            invisible="state != 'approved' or has_po == True"/>
                    <button name="button_view_po" string="Xem Po bù" type="object" class="btn-primary"
                            invisible="has_po != True"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="stock_picking"/>
                        <field name="complaint_date"/>
                        <field name="assigned_to"/>
                        <field name="attachments_complaint" invisible="attachments_complaint!=False"/>
                        <field name="attachments_progress" invisible="attachments_progress!=False"/>
                        <field name="product_ids" invisible="1"/>
                        <notebook>
                            <page string="Chi tiết khiếu nại">
                                <field name="complanit_line_ids" no_label="1">
                                    <list editable="bottom">
                                        <field name="product_id" domain="[('id', 'in', parent.product_ids)]"/>
                                        <field name="status"/>
                                        <field name="quantity"/>
                                        <field name="reason"/>
                                        <field name="resolution_notes"/>
                                    </list>
                                </field>
                            </page>
                            <page string="File thông tin khiếu nại" invisible="attachments_complaint==False">
                                <field name="attachments_complaint" widget="pdf_viewer"/>
                            </page>
                            <page string="File thông tin xử lý" invisible="attachments_progress==False">
                                <field name="attachments_progress" widget="pdf_viewer"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_complaint_ticket_list" model="ir.ui.view">
        <field name="name">complaint.ticket.list</field>
        <field name="model">complaint.ticket</field>
        <field name="arch" type="xml">
            <list string="Complaint Tickets">
                <field name="name"/>
                <field name="stock_picking"/>
                <field name="complaint_date"/>
                <field name="assigned_to"/>
                <field name="state"/>
            </list>
        </field>
    </record>
</odoo>