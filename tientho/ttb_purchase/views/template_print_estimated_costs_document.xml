<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="template_print_estimated_costs_document">
        <t t-call="web.report_layout" class="container-fluid p-0">
            <meta charset="utf-8"/>
            <style>
                @media only screen and (max-width: 576px) {
                .responsive .table {
                font-size: smaller;
                white-space: nowrap;
                }
                .responsive-1 .responsive-table-1 {
                white-space: nowrap;
                font-size: smaller;
                white-space: nowrap;
                min-width: 100%;
                }
                .responsive-table-4 {
                font-size: smaller;
                white-space: nowrap;
                font-size: smaller;
                min-width: 800px;
                }
                }

                @media only screen and (max-width: 800px) {
                .responsive table {
                font-size: smaller;
                white-space: nowrap;
                }
                .responsive-1 .responsive-table-1 {
                white-space: nowrap;
                font-size: smaller;
                min-width: 100%;
                }
                .responsive-table-4 {
                font-size: smaller;
                white-space: nowrap;
                font-size: smaller;
                min-width: 800px;
                }
                }
                @media only screen and (max-width: 990px) {
                .responsive table{
                font-size: smaller;
                white-space: nowrap;
                }
                .responsive-1 responsive-table-1 {
                white-space: nowrap;
                font-size: smaller;
                min-width: 100%;
                }
                .responsive-table-4 {
                font-size: smaller;
                white-space: nowrap;
                font-size: smaller;
                width: 100%;
                }
                }
                @media only screen and (max-width: 1200px) {
                .responsive table{
                font-size: smaller;
                }
                .responsive-table-4 {
                font-size: smaller;
                white-space: nowrap;
                font-size: smaller;
                width: 100%;
                }
                }
                @media only screen and (min-width: 1200px) {
                .responsive table{
                font-size: smaller;
                }
                .responsive-1 .responsive-table-1 {
                font-size: smaller;
                white-space: nowrap;
                font-size: smaller;
                width: 100%;
                }
                }
            </style>
            <div class="page p-0"
                 style="font-family :Time New Roman !important;margin-right:4%; margin-left:4%;">
                <div class="oe_structure">

                    <div class="col-sm-12 col-md-12 p-0">
                        <h2 style="width:100%; text-align:center;font-weight: 550;font-size: 30px;text-transform: uppercase; margin: 25px 0px;"
                            class="text-center bold">
                            <center>Phiếu đề nghị tạm ứng</center>
                        </h2>
                    </div>
                    <span class="text-center bold">
                        <center>
                            <t t-if="request_name">
                                <span class="text-center bold">
                                    <strong>Yêu cầu mua hàng:
                                        <t t-esc="request_name"/>
                                    </strong>
                                </span>
                            </t>
                            <br/>
                            <t t-if="po_name">
                                <span class="text-center bold">
                                    <strong>Đơn mua hàng:
                                        <t t-esc="po_name"/>
                                    </strong>
                                </span>
                            </t>
                            <br/>
                            <t t-if="partner">
                                <span class="text-center bold">
                                    <strong>Nhà cung cấp:
                                        <t t-esc="partner"/>
                                    </strong>
                                </span>
                            </t>
                            <br/>
                        </center>
                    </span>
                     <br/> <br/>
                    <div>
                        <div class="table-responsive-sm table-responsive-md responsive-1">
                            <table class="table-bordered responsive-table-1"
                                   style="border-collapse: collapse; border : border-box;">
                                <thead>
                                    <tr>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">STT
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Hình ảnh sản phẩm
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Mã sản phẩm
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Sản phẩm
                                        </th>
                                        <th style="text-align:center;width :15%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Mô tả
                                        </th>
                                        <th style="text-align:center;width :5%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Số lượng
                                        </th>
                                        <th style="text-align:center;width :5%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">CBM
                                        </th>
                                        <th style="text-align:center;width :5%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Số kiện
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Đơn vị
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Đơn giá(VNĐ)
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Đơn giá(Tệ)
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Giá nhập(VNĐ)
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Phí VAT
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Tổng nhập(chưa VAT)
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Tổng nhập(có VAT)
                                        </th>
                                        <th style="text-align:center;width :10%;background-color: #4cb1a7; color: #ffffff; border: 1px solid black;"
                                            class="table-item">Giá bán(VNĐ)
                                        </th>
                                    </tr>
                                </thead>

                                <tbody class="sale_tbody">
                                    <t t-set="i" t-value="1"/>
                                    <t t-set="price_total" t-value="0"/>
                                    <t t-set="price_subtotal" t-value="0"/>
                                    <t t-set="tax_total" t-value="0"/>
                                    <t t-foreach="docs" t-as="o">
                                        <tr>
                                            <td style="background-color: False; color: #000000; border: 1px solid black; text-align: center;">
                                                <span t-esc="i"/>
                                                <t t-set="i" t-value="i+1"/>
                                            </td>
                                            <td>
                                                <span>
                                                    <img t-if="o.product_image"
                                                         t-att-src="'data:image/jpg;base64,%s' % str(o.product_image).strip('b\'').strip('\'')"/>
                                                </span>
                                            </td>
                                            <td style="border: 1px solid black;text-align: left; background-color: False; color: #000000; !important;">
                                                <span t-esc="o.default_code"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: left; background-color: False; color: #000000; !important;">
                                                <span t-esc="o.product_id.name"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: left; background-color: False; color: #000000; !important;">
                                                <span t-esc="o.description"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="o.quantity"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="o.cbm"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="o.number_of_cases"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="o.uom_id.name"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="price_by_prd_dict[o.default_code][0]"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="price_by_prd_dict[o.default_code][1]"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="price_by_prd_dict[o.default_code][2]"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="price_by_prd_dict[o.default_code][5]-price_by_prd_dict[o.default_code][4]"/>
                                                <t t-set="tax_total" t-value="tax_total + (price_by_prd_dict[o.default_code][5]-price_by_prd_dict[o.default_code][4])"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="price_by_prd_dict[o.default_code][4]"/>
                                                <t t-set="price_subtotal" t-value="price_subtotal + price_by_prd_dict[o.default_code][4]"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="price_by_prd_dict[o.default_code][5]"/>
                                                <t t-set="price_total" t-value="price_total + price_by_prd_dict[o.default_code][5]"/>
                                            </td>
                                            <td style="border: 1px solid black;text-align: center; background-color: False; color: #000000; !important;">
                                                <span t-esc="price_by_prd_dict[o.default_code][3]"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <br/>
                        <div>
                            <span>
                                <strong>Tổng tiền đề nghị tạm ứng (trước thuế):
                                <span t-esc="price_subtotal"/>(VNĐ)</strong>
                            </span>
                            <br/>
                            <span>
                                <strong>Tổng thuế:
                                <span t-esc="tax_total"/>(VNĐ)</strong>
                            </span>
                            <br/>
                            <span>
                                <strong>Tổng tiền đề nghị tạm ứng (trước thuế):
                                <span t-esc="price_total"/>(VNĐ)</strong>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>