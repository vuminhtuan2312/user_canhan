<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="purchase_batch_form" model="ir.ui.view">
        <field name="name">Tổng hợp yêu cầu mua hàng</field>
        <field name="model">ttb.purchase.batch</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="%(ttb_purchase.purchase_batch_select_pr_action)d" type="action" string="Chọn PR" class="btn-primary" invisible="line_ids"/>
                    <button name="action_create_po" groups="ttb_purchase.group_purchase_expert" type="object" string="Tạo PO" class="btn-primary" confirm="Bạn chắc chắn tạo PO với các Sản phẩm đã chọn Nhà cung cấp?" invisible="state == 'created_po' or not line_ids"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_to_po"
                                class="oe_stat_button"
                                icon="fa-credit-card" invisible="po_count == 0">
                            <field name="po_count" widget="statinfo" string="Đơn mua hàng"/>
                            <field name='po_ids' widget="many2many_tags" invisible="1"/>
                        </button>
                        <button type="object" name="action_to_pr"
                                class="oe_stat_button"
                                icon="fa-credit-card" invisible="pr_count == 0">
                            <field name="pr_count" widget="statinfo" string="Yêu cầu mua hàng"/>
                            <field name='pr_ids' widget="many2many_tags" invisible="1"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state != 'new'"/>
                            <field name="user_id" readonly="state != 'new'"/>
                            <field name="company_id" groups="base.group_multi_company" invisible="1"/>
                            <field name="currency_id" groups="base.group_multi_currency" invisible="1"/>
                        </group>
                        <group>
                            <field name="pr_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="branch_id"/>
                                    <field name="date"/>
                                </list>
                            </field>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết yêu cầu" name="detail">
                            <field name="line_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="default_code"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="uom_id" readonly="1"/>
                                    <field name="partner_id" readonly="po_line_ids" widget="res_partner_many2one" context="{'res_partner_search_mode': 'supplier'}"/>
                                    <field name="po_line_ids" widget="many2many_tags" column_invisible="1"/>
                                    <field name="vendor1"/>
                                    <field name="vendor2"/>
                                    <field name="vendor3"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="default_code"/>
                                            <field name="product_id"/>
                                            <field name="quantity"/>
                                            <field name="uom_id"/>
                                        </group>
                                        <group>
                                            <field name="partner_id" readonly="po_line_ids"/>
                                            <field name="po_line_ids" widget="many2many_tags" column_invisible="1"/>
                                            <field name="vendor1"/>
                                            <field name="vendor2"/>
                                            <field name="vendor3"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="purchase_batch_list" model="ir.ui.view">
        <field name="name">Tổng hợp yêu cầu mua hàng</field>
        <field name="model">ttb.purchase.batch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="pr_ids" widget="many2many_tags"/>
                <field name="state"/>
                <field name="company_id" column_invisible="1" groups="base.group_multi_company"/>
                <field name="currency_id" column_invisible="1" groups="base.group_multi_currency"/>
            </list>
        </field>
    </record>

    <record id="purchase_batch_search" model="ir.ui.view">
        <field name="name">Tổng hợp yêu cầu mua hàng</field>
        <field name="model">ttb.purchase.batch</field>
        <field name="arch" type="xml">
            <search>
                <field name="date"/>
                <field name="user_id"/>
                <filter string="Công việc của tôi" name="my_request" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Đang thực hiện" name="state_po_creating" domain="[('state','=','po_creating')]"/>
                <filter string="Đã hoàn thành" name="state_po_created" domain="[('state','=','po_created')]"/>

                <group expand="1" string="Group By">
                    <filter string="Ngày thực hiện" name="groupby_date" context="{'group_by': 'date:month'}"/>
                    <filter string="Người thực hiện" name="groupby_user_id" context="{'group_by':'user_id'}"/>
                    <filter string="Trạng thái" name="groupby_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="purchase_batch_action" model="ir.actions.act_window">
        <field name="name">Chọn nhà cung cấp</field>
        <field name="res_model">ttb.purchase.batch</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>