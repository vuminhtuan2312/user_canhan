<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ttb_purchase.MultiFileViewer">
        <div class="o_field_multi_file_viewer">
            <t t-if="state.loading">
                <div class="text-center p-3">
                    <i class="fa fa-spinner fa-spin fa-2x"/>
                    <p>Đang tải...</p>
                </div>
            </t>
            <t t-elif="!hasFiles">
                <div class="alert alert-info text-center" role="alert">
                    <i class="fa fa-info-circle"/> Chưa có file đính kèm
                </div>
                <!-- Add file button when empty -->
                <div class="text-center mt-2" t-if="!props.readonly">
                    <button class="btn btn-primary" t-on-click="onAddFile">
                        <i class="fa fa-plus"/> Thêm file
                    </button>
                </div>
            </t>
            <t t-else="">
                <!-- Action buttons bar -->
                <div class="d-flex justify-content-between mb-2" t-if="!props.readonly">
                    <button class="btn btn-sm btn-success" t-on-click="onAddFile">
                        <i class="fa fa-plus"/> Thêm file
                    </button>
                    <button class="btn btn-sm btn-danger ms-1"
                            t-on-click="onDeleteFile"
                            title="Xóa file">
                        <i class="fa fa-trash"/> Xóa
                    </button>
                </div>

                <!-- Navigation controls -->
                <div class="d-flex align-items-center justify-content-between mb-2 p-2 bg-light border rounded">
                    <button class="btn btn-sm btn-secondary"
                            t-on-click="onPrevious"
                            t-att-disabled="!canGoPrevious">
                        <i class="fa fa-chevron-left"/> Trước
                    </button>

                    <div class="text-center">
                        <strong t-esc="state.currentIndex + 1"/> / <t t-esc="totalFiles"/>
                        <br/>
                        <small class="text-muted" t-esc="currentFile.name"/>
                    </div>

                    <button class="btn btn-sm btn-secondary"
                            t-on-click="onNext"
                            t-att-disabled="!canGoNext">
                        Sau <i class="fa fa-chevron-right"/>
                    </button>
                </div>

                <!-- File viewer -->
                <div class="o_file_viewer border rounded" style="min-height: 500px; max-height: 700px; overflow: auto;">
                    <t t-if="isPDF">
                        <iframe t-att-src="fileUrl"
                                style="width: 100%; height: 650px; border: none;"
                                title="PDF Viewer"/>
                    </t>
                    <t t-elif="isImage">
                        <img t-att-src="fileUrl"
                             class="img-fluid w-100"
                             t-att-alt="currentFile.name"/>
                    </t>
                    <t t-else="">
                        <div class="text-center p-5">
                            <i class="fa fa-file-o fa-5x text-muted mb-3"/>
                            <p class="text-muted">
                                Không thể xem trước file này.<br/>
                                Vui lòng tải xuống để xem.
                            </p>
                            <button class="btn btn-primary" t-on-click="onDownload">
                                <i class="fa fa-download"/> Tải xuống
                            </button>
                        </div>
                    </t>
                </div>

                <!-- Download button for all files -->
                <div class="text-end mt-2">
                    <button class="btn btn-sm btn-link" t-on-click="onDownload">
                        <i class="fa fa-download"/> Tải xuống file này
                    </button>
                </div>
            </t>
        </div>
    </t>
</templates>

